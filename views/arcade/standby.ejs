<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chemistry Arcade | Standby</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-950 overflow-hidden font-sans">

    <div class="min-h-screen flex flex-col items-center justify-center relative">
        
        <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
            <div class="absolute top-10 left-10 w-64 h-64 bg-cyan-500 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
            <div class="absolute bottom-10 right-10 w-64 h-64 bg-purple-500 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
        </div>

        <div class="z-10 text-center mb-10">
            <h1 class="text-7xl font-black text-white tracking-tighter italic">
                CHEMISTRY <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600">ARCADE</span>
            </h1>
            <p class="text-slate-400 mt-4 tracking-[0.4em] uppercase text-xs font-bold animate-pulse">
                System Ready • Please Scan QR Code
            </p>
        </div>

        <div class="z-10 relative">
            <div class="w-[450px] h-[450px] bg-slate-900/80 backdrop-blur-xl border-4 border-slate-800 rounded-[3rem] p-6 shadow-[0_0_50px_rgba(0,0,0,0.5)] flex flex-col items-center justify-center overflow-hidden">
                
                <div id="reader" class="w-full h-full rounded-2xl overflow-hidden border border-slate-700 bg-black relative">
                    <div class="absolute top-0 left-0 w-full h-1 bg-cyan-400 shadow-[0_0_15px_rgba(34,211,238,1)] z-20 animate-scan"></div>
                </div>

            </div>

            <div class="absolute -top-4 -left-4 w-12 h-12 border-t-8 border-l-8 border-cyan-500 rounded-tl-2xl"></div>
            <div class="absolute -top-4 -right-4 w-12 h-12 border-t-8 border-r-8 border-cyan-500 rounded-tr-2xl"></div>
            <div class="absolute -bottom-4 -left-4 w-12 h-12 border-b-8 border-l-8 border-cyan-500 rounded-bl-2xl"></div>
            <div class="absolute -bottom-4 -right-4 w-12 h-12 border-b-8 border-r-8 border-cyan-500 rounded-br-2xl"></div>
        </div>

        <div class="z-10 mt-12 flex items-center gap-6 text-slate-500 font-mono text-sm uppercase tracking-widest">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-green-500 rounded-full animate-ping"></span>
                <span>Camera Active</span>
            </div>
            <div class="h-4 w-[1px] bg-slate-800"></div>
            <div>Server: <span class="text-slate-300 font-bold">Localhost:3000</span></div>
        </div>

    </div>

    <style>
        @keyframes scan {
            0% { top: 0; }
            100% { top: 100%; }
        }
        .animate-scan {
            animation: scan 2.5s ease-in-out infinite;
        }
        @keyframes blob {
            0% { transform: translate(0px, 0px) scale(1); }
            33% { transform: translate(30px, -50px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
            100% { transform: translate(0px, 0px) scale(1); }
        }
        .animate-blob {
            animation: blob 7s infinite;
        }
        .animation-delay-2000 {
            animation-delay: 2s;
        }
    </style>

    <script>
        // Scanner Configuration
        function onScanSuccess(decodedText, decodedResult) {
            // Ihinto ang scanner para hindi mag-multiple scan
            html5QrcodeScanner.clear();
            
            // I-redirect sa backend route para i-verify ang token
            // Gagamitin natin ang endpoint na gagawin natin sa student.js
            window.location.href = `/arcade/verify?token=${decodedText}`;
        }

        function onScanFailure(error) {
            // Hayaan lang natin, mag-papatuloy ang scan cycle
        }

        let html5QrcodeScanner = new Html5QrcodeScanner(
            "reader", 
            { 
                fps: 10, 
                qrbox: {width: 250, height: 250},
                // Ito ang mahalaga para sa Raspberry Pi: i-set ang camera
                aspectRatio: 1.0 
            },
            /* verbose= */ false
        );
        html5QrcodeScanner.render(onScanSuccess, onScanFailure);
    </script>
</body>
</html>