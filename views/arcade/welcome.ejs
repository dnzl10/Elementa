<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome Player | Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-950 text-white min-h-screen flex flex-col items-center justify-center p-10 overflow-hidden">

    <div class="z-10 text-center space-y-8 animate-in fade-in zoom-in duration-500">
        
        <div class="relative inline-block">
            <div class="w-48 h-48 rounded-full border-4 border-cyan-500 p-1 shadow-[0_0_50px_rgba(6,182,212,0.5)] bg-slate-900 overflow-hidden">
                <img src="/profile_uploads/<%= user.profile_pic || 'default-avatar.png' %>" 
                     class="w-full h-full rounded-full object-cover">
            </div>
            <div class="absolute bottom-4 right-4 bg-green-500 w-10 h-10 rounded-full border-8 border-slate-950"></div>
        </div>

        <div>
            <h1 class="text-6xl font-black italic tracking-tighter mb-2">
                GOOD DAY, <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 uppercase">
                    <%= user.first_name %>!
                </span>
            </h1>
            <p class="text-slate-400 font-mono tracking-widest uppercase">Identity Verified • ID: <%= user.lrn_number || user.faculty_id %></p>
        </div>

        <div class="bg-slate-900/80 border-y-2 border-cyan-500/30 py-6 px-12 backdrop-blur-md">
            <p class="text-xs text-cyan-400 font-bold tracking-[0.5em] uppercase mb-2">Target Assessment:</p>
            <h2 class="text-4xl font-bold text-white uppercase tracking-tight">
                <%= assessment.assessment_name %>
            </h2>
            <div class="mt-2 inline-block px-4 py-1 bg-cyan-500/10 border border-cyan-500/50 rounded-full">
                <span class="text-cyan-400 text-sm font-black uppercase"><%= assessment.assessment_type %></span>
            </div>
        </div>

        <div class="mt-12 flex flex-col items-center gap-4">
            <div class="flex items-center gap-6">
                <div class="px-8 py-5 bg-green-600 rounded-2xl border-b-8 border-green-800 text-4xl font-black shadow-2xl animate-pulse">
                    ENTER
                </div>
                <span class="text-3xl font-bold text-slate-300">TO PROCEED</span>
            </div>
            <p class="text-slate-500 italic text-sm mt-4">Press ESCAPE to cancel and log out</p>
        </div>
    </div>

    <div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-10">
        <i class="fas fa-atom text-[20rem] absolute -top-20 -left-20 animate-spin-slow"></i>
        <i class="fas fa-flask text-[15rem] absolute -bottom-10 -right-10"></i>
    </div>

    <style>
        .animate-spin-slow { animation: spin 15s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>

    <script>
        // Physical Keyboard/Button Listener
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                // Next step: Direct to Guidelines page
                window.location.href = '/arcade/guidelines/<%= user.qr_code_token %>';
            }
            if (e.key === 'Escape') {
                // Cancel and return to standby
                window.location.href = '/arcade/standby';
            }
        });
    </script>
</body>
</html>