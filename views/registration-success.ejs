<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Setup - Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        details > summary { list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
        .dropdown-card { @apply bg-white border border-slate-200 rounded-2xl overflow-hidden mb-4 shadow-sm; }
        .section-header { @apply flex items-center justify-between p-4 cursor-pointer hover:bg-slate-50 transition; }
        .input-readonly { @apply bg-slate-100 text-slate-500 cursor-not-allowed; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen p-4 md:p-10 font-sans">

    <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
            <div class="bg-green-500 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg shadow-green-200">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <h1 class="text-3xl font-black text-slate-800">Account Verified!</h1>
            <p class="text-slate-500">Please personalize your profile before proceeding to the dashboard.</p>
        </div>

        <form action="/finalize-profile" method="POST" enctype="multipart/form-data" class="space-y-4">
            
            <div class="dropdown-card">
                <div class="p-6 flex flex-col md:flex-row items-center gap-6">
                    <div class="relative group">
                        <div class="w-32 h-32 bg-slate-200 rounded-2xl border-4 border-white shadow-xl overflow-hidden flex items-center justify-center text-slate-400 text-4xl">
                            <img id="preview" src="/profile_uploads/<%= user.profile_pic || 'default_avatar.png' %>" class="w-full h-full object-cover">
                        </div>
                        <label for="fileInput" class="absolute -bottom-2 -right-2 bg-blue-600 text-white p-2 rounded-lg shadow-lg hover:bg-blue-700 cursor-pointer transition">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path></svg>
                        </label>
                        <input type="file" name="profilePic" id="fileInput" class="hidden" accept="image/*" onchange="previewImage(this)">
                    </div>
                    <div class="flex-1 space-y-2">
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Profile Media</p>
                        <p class="text-xs text-slate-500">Optimized for badges: <span class="font-mono text-blue-600">gif, jpeg, jpg, png</span></p>
                        <input type="text" name="pic_description" placeholder="Short picture description..." class="w-full border-b border-slate-200 p-2 text-sm outline-none focus:border-blue-500">
                        <button type="button" onclick="deleteImage()" class="text-xs text-red-500 font-bold hover:underline">Delete Picture</button>
                    </div>
                </div>
            </div>

            <details class="dropdown-card" open>
                <summary class="section-header">
                    <span class="font-bold text-slate-700 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        General Information
                    </span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
                </summary>
                <div class="p-6 pt-0 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="text-[10px] font-bold text-slate-400 uppercase">First Name</label>
                        <input type="text" value="<%= user.first_name %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Middle Name</label>
                        <input type="text" value="<%= user.middle_name %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Last Name</label>
                        <input type="text" value="<%= user.last_name %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Suffix</label>
                        <input type="text" value="<%= user.suffix %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                    </div>
                    <div class="md:col-span-2">
                        <label class="text-[10px] font-bold text-blue-600 uppercase">City / Town (Editable)</label>
                        <input type="text" name="city_town" placeholder="e.g. Labo, Camarines Norte" class="w-full p-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-blue-500 transition">
                    </div>
                    <div class="md:col-span-2">
                        <label class="text-[10px] font-bold text-slate-400 uppercase">Self Description</label>
                        <input type="text" name="self_description" placeholder="e.g. Chemistry Enthusiast" class="w-full p-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-blue-500 transition">
                    </div>
                </div>
            </details>

            <details class="dropdown-card">
                <summary class="section-header">
                    <span class="font-bold text-slate-700 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        Additional Names
                    </span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
                </summary>
                <div class="p-6 pt-0 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="text" name="fname_phonetic" placeholder="First Name - Phonetic" class="w-full p-3 rounded-xl border border-slate-200 outline-none">
                    <input type="text" name="mname_phonetic" placeholder="Middle Name - Phonetic" class="w-full p-3 rounded-xl border border-slate-200 outline-none">
                    <input type="text" name="lname_phonetic" placeholder="Last Name - Phonetic" class="w-full p-3 rounded-xl border border-slate-200 outline-none">
                    <input type="text" name="alt_name" placeholder="Alternative Name (Nickname)" class="w-full p-3 rounded-xl border border-slate-200 outline-none">
                </div>
            </details>

            <div class="dropdown-card p-6">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Interests (Tags)</label>
                <input type="text" name="interests" placeholder="Organic Chemistry, Gaming, Web Dev (Separate with commas)" 
                       class="w-full p-3 rounded-xl border border-slate-200 outline-none focus:border-blue-500">
                <p class="text-[10px] text-slate-400 mt-2">Enter your interests to find competitive matches easier.</p>
            </div>

            <details class="dropdown-card">
                <summary class="section-header">
                    <span class="font-bold text-slate-700 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Other Information
                    </span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
                </summary>
                <div class="p-6 pt-0 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">ID Number</label>
                            <input type="text" value="<%= user.lrn_number || user.faculty_id %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">School Name</label>
                            <input type="text" value="Mabini Colleges" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest"><%= user.role === 'Student' ? 'Strand' : 'Department' %></label>
                            <input type="text" value="<%= user.role === 'Student' ? user.strand : 'Science Dept' %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Section</label>
                            <input type="text" value="<%= user.section %>" readonly class="w-full p-3 rounded-xl input-readonly border border-slate-100">
                        </div>
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">Mobile Number (Editable)</label>
                        <input type="text" name="mobile" placeholder="09XXXXXXXXX" class="w-full p-3 rounded-xl border border-slate-200 outline-none">
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">Home Address (Editable)</label>
                        <textarea name="address" class="w-full p-3 rounded-xl border border-slate-200 outline-none h-20"></textarea>
                    </div>
                </div>
            </details>

            <div class="dropdown-card p-6 flex items-center justify-between">
                <div>
                    <h3 class="font-bold text-slate-700">Arcade QR Login</h3>
                    <p class="text-xs text-slate-500">Toggle visibility of your unique login token.</p>
                </div>
                <button type="button" onclick="toggleQR()" class="bg-slate-100 hover:bg-slate-200 p-3 rounded-xl transition">
                    <svg id="qrEye" class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                </button>
            </div>

            <div id="qrContainer" class="hidden text-center p-6 bg-white rounded-2xl border-2 border-dashed border-slate-200">
                <p class="text-[10px] font-mono text-slate-400 mb-3 uppercase tracking-widest">Your Private Access Token</p>
                
                <div class="w-48 h-48 bg-white mx-auto rounded-xl flex items-center justify-center shadow-inner p-2">
                    <% if (locals.qrCodeData) { %>
                        <img src="<%= qrCodeData %>" alt="Arcade QR Code" class="w-full h-full object-contain">
                    <% } else { %>
                        <div class="text-red-500 text-xs flex flex-col items-center">
                            <svg class="w-8 h-8 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                            QR Failed to load
                        </div>
                    <% } %>
                </div>
                
                <p class="mt-3 text-xs font-bold text-slate-600 tracking-wider font-mono">
                    <%= user.qr_code_token %>
                </p>
            </div>

            <div class="pt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                <button type="submit" class="bg-blue-600 text-white p-4 rounded-2xl font-bold shadow-xl hover:bg-blue-700 transition active:scale-95 order-2 md:order-1">
                    Confirm & Save Profile
                </button>
                <a href="/dashboard" class="bg-slate-900 text-white p-4 rounded-2xl font-bold shadow-xl hover:bg-black transition text-center active:scale-95 order-1 md:order-2">
                    Go to Dashboard
                </a>
            </div>
        </form>
    </div>

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('preview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function deleteImage() {
            if(confirm("Are you sure you want to remove your profile picture?")) {
                document.getElementById('preview').src = "/profile_uploads/default_avatar.png";
                document.getElementById('fileInput').value = "";
            }
        }

        function toggleQR() {
            const container = document.getElementById('qrContainer');
            container.classList.toggle('hidden');
        }
    </script>
</body>
</html>