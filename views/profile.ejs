<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.first_name %>'s Profile | Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .card-base { @apply bg-white rounded-[2rem] border border-slate-100 shadow-sm transition-all duration-300; }
        .card-hover:hover { @apply shadow-xl shadow-slate-200/50 -translate-y-1 border-blue-100; }
        .label-style { @apply text-[10px] font-extrabold text-slate-400 uppercase tracking-[0.15em] mb-1.5 block; }
        .value-style { @apply text-slate-800 font-semibold text-[15px] leading-tight; }
        .icon-box { @apply w-10 h-10 rounded-xl flex items-center justify-center text-lg; }
        
        /* Custom Scrollbar for the main content if needed */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    </style>
</head>
<body class="bg-[#fcfdfe] text-slate-900 overflow-x-hidden">

    <aside class="fixed top-0 left-0 h-screen w-64 bg-slate-900 border-r border-slate-100 z-50 flex flex-col p-6">
        <div class="mb-10 px-2">
            <span class="text-xl font-extrabold tracking-tighter text-slate-600">ELEM<span class="text-blue-600">ENTA</span></span>
        </div>

        <nav class="flex-1 space-y-2">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-4 px-2">User Menu</p>
            <a href="/profile" class="flex items-center gap-3 px-4 py-3 bg-blue-50 text-blue-600 rounded-2xl font-bold text-sm transition-all">
                <i class="fa-solid fa-user-circle"></i> View Profile
            </a>
            <a href="/settings" class="flex items-center gap-3 px-4 py-3 text-slate-500 hover:bg-slate-50 rounded-2xl font-bold text-sm transition-all">
                <i class="fa-solid fa-gear"></i> Account Settings
            </a>
            <a href="/inbox" class="flex items-center gap-3 px-4 py-3 text-slate-500 hover:bg-slate-50 rounded-2xl font-bold text-sm transition-all">
                <i class="fa-solid fa-envelope"></i> Inbox
            </a>
            <a href="/progress" class="flex items-center gap-3 px-4 py-3 text-slate-500 hover:bg-slate-50 rounded-2xl font-bold text-sm transition-all">
                <i class="fa-solid fa-chart-line"></i> Scores/Progress
            </a>
        </nav>

        <div class="p-3 border-t border-slate-800">
            <a href="/logout" class="flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-50 rounded-2xl font-bold text-sm transition-all">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </aside>

    <header class="fixed top-0 left-64 right-0 h-20 bg-white/80 backdrop-blur-md border-b border-slate-100 z-40 px-8 flex items-center">
        <!-- CENTER NAVIGATION -->
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-6">
            <a href="/home" class="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors" title="Home">
                Home <i class="fa-solid fa-house text-lg"></i>
            </a>
            <a href="/dashboard" class="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors" title="Dashboard">
                Dashboard <i class="fa-solid fa-gauge-high text-lg"></i>
            </a>
            <a href="/events" class="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors" title="Events">
                Events <i class="fa-solid fa-calendar-days text-lg"></i>
            </a>
            <a href="/subjects" class="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors" title="Subjects">
                Subjects <i class="fa-solid fa-book text-lg"></i>
            </a>
            <a href="/leaderboards" class="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors" title="Leaderboards">
                Leaderboards <i class="fa-solid fa-trophy text-lg"></i>
            </a>
            <a href="/forums" class="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors" title="Forums">
                Forums <i class="fa-solid fa-comments text-lg"></i>
            </a>
        </div>
        
    </header>

    <main class="ml-64 pt-20">
        <div class="max-w-6xl mx-auto px-8 pt-10 pb-16">
            
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
                <div>
                    <nav class="flex items-center gap-2 text-xs font-bold text-blue-600 uppercase tracking-widest mb-2">
                        <a href="/dashboard" class="hover:underline">Dashboard</a>
                        <i class="fa-solid fa-chevron-right text-[8px] text-slate-300"></i>
                        <span class="text-slate-400">Profile View</span>
                    </nav>
                    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Personal <span class="text-blue-600">Space.</span></h1>
                </div>
                <div class="flex gap-3 w-full md:w-auto">
                    <a href="/edit-profile" class="flex-1 md:flex-none bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold text-sm hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 active:scale-95 flex items-center justify-center gap-2">
                        <i class="fa-solid fa-pen-nib text-xs"></i> Customize Profile
                    </a>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                
                <div class="lg:col-span-4 space-y-8">
                    <div class="card-base p-8 text-center relative overflow-hidden group">
                        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
                        <div class="relative inline-block mb-6">
                            <div class="w-44 h-44 rounded-[3rem] overflow-hidden ring-[12px] ring-slate-50 shadow-inner group-hover:scale-105 transition-transform duration-500">
                                <img src="/profile_uploads/<%= user.profile_pic || 'default_avatar.png' %>" class="w-full h-full object-cover" alt="Profile">
                            </div>
                            <div class="absolute -bottom-2 -right-2 bg-white p-2 rounded-2xl shadow-lg">
                                <div class="bg-green-500 w-4 h-4 rounded-full border-2 border-white"></div>
                            </div>
                        </div>
                        <h2 class="text-2xl font-extrabold text-slate-800 mb-1"><%= user.first_name %> <%= user.last_name %></h2>
                        <p class="text-blue-600 font-bold text-[11px] uppercase tracking-widest mb-6"><%= user.role %></p>
                        
                        <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100 italic text-slate-500 text-sm">
                            "<%= user.pic_description || 'No status set.' %>"
                        </div>
                    </div>

                    <div class="card-base p-8 text-center relative overflow-hidden group bg-slate-900 rounded-3xl">
                        <div class="relative z-10">
                            <h3 class="text-white font-bold text-lg mb-6">Unique QR Code</h3>
                            <div class="relative cursor-pointer mx-auto max-w-[200px]" onclick="toggleQR()">
                                <div id="qrOverlay" class="absolute inset-0 z-20 bg-slate-800/90 backdrop-blur-md rounded-3xl flex flex-col items-center justify-center transition-all duration-500">
                                    <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mb-3">
                                        <i class="fa-solid fa-lock text-white"></i>
                                    </div>
                                    <span class="text-white text-[9px] font-black uppercase tracking-[0.2em]">Reveal Code</span>
                                </div>
                                <div class="bg-white p-5 rounded-[2.5rem]">
                                    <img src="<%= qrCodeData %>" alt="QR" class="w-full h-auto">
                                </div>
                            </div>
                            <div class="mt-6 pt-6 border-t border-white/10">
                                <span class="label-style text-slate-500">Private Token</span>
                                <code class="text-blue-400 font-mono text-xs tracking-tighter"><%= user.qr_code_token %></code>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-8 space-y-8">
                    <section class="card-base card-hover bg-white rounded-3xl">
                        <div class="flex items-center gap-4 px-8 py-6 border-b border-slate-50">
                            <div class="icon-box bg-blue-50 text-blue-600"><i class="fa-solid fa-address-card"></i></div>
                            <h3 class="text-lg font-extrabold text-slate-800">General Information</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 p-8">
                            <div><span class="label-style">First Name</span><p class="value-style"><%= user.first_name %></p></div>
                            <div><span class="label-style">Middle Name</span><p class="value-style"><%= user.middle_name || '—' %></p></div>
                            <div><span class="label-style">Last Name</span><p class="value-style"><%= user.last_name %></p></div>
                            <div><span class="label-style">Suffix</span><p class="value-style"><%= user.suffix || 'None' %></p></div>
                            <div><span class="label-style">City / Town</span><p class="value-style"><%= user.city_town %></p></div>
                            <div class="md:col-span-2 lg:col-span-3 pt-4">
                                <span class="label-style">Self Description</span>
                                <p class="text-slate-600 text-[14px] leading-relaxed bg-slate-50 p-4 rounded-2xl border border-slate-100">
                                    <%= user.self_description || 'The user has not shared a biography yet.' %>
                                </p>
                            </div>
                        </div>
                    </section>

                    <section class="card-base card-hover rounded-3xl bg-white">
                        <div class="flex items-center gap-4 px-8 py-6 border-b border-slate-50">
                            <div class="icon-box bg-purple-50 text-purple-600"><i class="fa-solid fa-fingerprint"></i></div>
                            <h3 class="text-lg font-extrabold text-slate-800">Other Details</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                            <div class="space-y-6">
                                <div><span class="label-style">Full Phonetic Name</span>
                                    <p class="value-style text-slate-500 text-xs">
                                        <%= user.first_name_phonetic %> <%= user.middle_name_phonetic %> <%= user.last_name_phonetic %>
                                    </p>
                                </div>
                                <div><span class="label-style">Alias / Nickname</span><p class="value-style"><%= user.alternative_name || '—' %></p></div>
                            </div>
                            <div>
                                <span class="label-style">Field Interests</span>
                                <div class="flex flex-wrap gap-2 mt-3">
                                    <% if(user.interests) { %>
                                        <% user.interests.split(',').forEach(tag => { %>
                                            <span class="bg-purple-50 text-purple-700 text-[10px] font-extrabold px-4 py-2 rounded-xl border border-purple-100">#<%= tag.trim().toUpperCase() %></span>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-slate-400 text-xs italic">No tags selected</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="card-base card-hover rounded-3xl bg-white">
                        <div class="flex items-center gap-4 px-8 py-6 border-b border-slate-50">
                            <div class="icon-box bg-orange-50 text-orange-600"><i class="fa-solid fa-building-columns"></i></div>
                            <h3 class="text-lg font-extrabold text-slate-800">Institutional Data</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 p-8">
                            <div><span class="label-style">Official ID</span><p class="value-style font-mono text-blue-600"><%= user.lrn_number || user.faculty_id %></p></div>
                            <div class="lg:col-span-2"><span class="label-style">Campus</span><p class="value-style">Mabini Colleges, Inc.</p></div>
                            <div><span class="label-style">Classification</span><p class="value-style"><%= user.strand %></p></div>
                            <div><span class="label-style">Group / Section</span><p class="value-style"><%= user.section %></p></div>
                            <div><span class="label-style">Mobile</span><p class="value-style"><%= user.mobile_number %></p></div>
                            <div class="md:col-span-2 lg:col-span-3">
                                <span class="label-style">Residential Address</span>
                                <p class="value-style"><%= user.home_address %></p>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <footer class="mt-16 py-8 border-t border-slate-100 bg-white/80 backdrop-blur-md">
                <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                    <div class="text-center md:text-left">
                        <p class="text-sm text-slate-500 font-medium">
                            &copy; 2026 <span class="text-blue-600 font-bold">Mabini College</span>. All rights reserved.
                        </p>
                    </div>
                    <div class="flex gap-6">
                        <a href="/privacy" class="text-xs font-bold text-slate-400 hover:text-blue-600 transition">Privacy</a>
                        <a href="/terms" class="text-xs font-bold text-slate-400 hover:text-blue-600 transition">Terms</a>
                        <a href="/support" class="text-xs font-bold text-slate-400 hover:text-blue-600 transition">Support</a>
                    </div>
                </div>
            </footer>
        </div>
    </main>

    <script>
        function toggleQR() {
            const overlay = document.getElementById('qrOverlay');
            overlay.classList.toggle('opacity-0');
            overlay.classList.toggle('pointer-events-none');
            overlay.classList.toggle('scale-95');
        }
    </script>
</body>
</html>