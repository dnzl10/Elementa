<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission Briefing | Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-950 text-white min-h-screen flex flex-col items-center justify-center p-10 overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-10">
        <i class="fas fa-atom text-[18rem] absolute -top-16 -left-16 animate-spin-slow text-cyan-400"></i>
        <i class="fas fa-microscope text-[15rem] absolute -bottom-12 -right-12 text-blue-500"></i>
        <i class="fas fa-dna text-[12rem] absolute top-1/4 -right-10 text-cyan-500 rotate-12"></i>
        <i class="fas fa-project-diagram text-[10rem] absolute bottom-1/4 -left-8 text-blue-600 -rotate-12"></i>
    </div>

    <style>
        .animate-spin-slow { animation: spin 15s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>

    <div class="max-w-4xl w-full bg-slate-900/50 border-2 border-cyan-500/30 rounded-[3rem] p-12 backdrop-blur-xl relative overflow-hidden shadow-2xl">
        
        <div class="text-center mb-10">
            <h2 class="text-sm font-black tracking-[0.5em] text-cyan-400 uppercase mb-2">Mission Briefing</h2>
            <h1 class="text-5xl font-black italic uppercase tracking-tighter">How to <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Play</span></h1>
        </div>

        <div class="grid grid-cols-2 gap-8 mb-12">
            
            <div class="flex gap-4 items-start p-4 bg-slate-800/50 rounded-2xl border border-slate-700 shadow-inner">
                <div class="w-12 h-12 bg-cyan-500/20 rounded-lg flex items-center justify-center text-cyan-400 font-bold text-xl">1</div>
                <div>
                    <h3 class="font-bold text-lg text-white"><%= total %> Questions</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        Mixed Difficulty: <br>
                        <span class="text-cyan-400 font-bold"><%= dist.easy %> Easy</span>, 
                        <span class="text-blue-400 font-bold"><%= dist.average %> Average</span>, 
                        <span class="text-purple-400 font-bold"><%= dist.difficult %> Difficult</span>.
                    </p>
                </div>
            </div>

            <div class="flex gap-4 items-start p-4 bg-slate-800/50 rounded-2xl border border-slate-700 shadow-inner">
                <div class="w-12 h-12 bg-cyan-500/20 rounded-lg flex items-center justify-center text-cyan-400 font-bold text-xl">2</div>
                <div>
                    <h3 class="font-bold text-lg text-white">Rapid Response</h3>
                    <p class="text-slate-400 text-sm">You only have <span class="text-yellow-400 font-bold text-base">5-10 seconds</span> per question. Think fast!</p>
                </div>
            </div>

            <div class="flex gap-4 items-start p-4 bg-slate-800/50 rounded-2xl border border-slate-700 shadow-inner">
                <div class="w-12 h-12 bg-cyan-500/20 rounded-lg flex items-center justify-center text-cyan-400 font-bold text-xl">3</div>
                <div>
                    <h3 class="font-bold text-lg text-white">Arcade Controls</h3>
                    <p class="text-slate-400 text-sm">Use physical buttons <span class="text-white font-mono font-bold">1, 2, 3, 4</span> to select your answer.</p>
                </div>
            </div>

            <div class="flex gap-4 items-start p-4 bg-slate-800/50 rounded-2xl border border-slate-700 shadow-inner">
                <div class="w-12 h-12 bg-cyan-500/20 rounded-lg flex items-center justify-center text-cyan-400 font-bold text-xl">4</div>
                <div>
                    <h3 class="font-bold text-lg text-white">EXP Rewards</h3>
                    <p class="text-slate-400 text-sm">Correct answers grant EXP. Accumulate points to climb the Leaderboard!</p>
                </div>
            </div>
        </div>

        <div class="flex flex-col items-center justify-center border-t border-slate-800 pt-8">
            <div class="flex items-center gap-6">
                <div class="px-10 py-4 bg-cyan-500 rounded-xl text-3xl font-black text-slate-950 shadow-[0_0_30px_rgba(6,182,212,0.4)] animate-pulse">
                    PRESS 1
                </div>
                <span class="text-2xl font-bold text-slate-300 uppercase italic tracking-widest">To Start Mission</span>
            </div>
            <p class="text-slate-500 text-[10px] mt-6 uppercase tracking-[0.3em]">System Note: Assessment session will be recorded upon starting.</p>
        </div>
    </div>

    <script>
        window.addEventListener('keydown', (e) => {
            // Button '1' triggers the game
            if (e.key === '1') {
                window.location.href = '/arcade/game/<%= user.qr_code_token %>';
            }
            // Escape cancels and goes back to standby
            if (e.key === 'Escape') {
                window.location.href = '/arcade/standby';
            }
        });
    </script>
</body>
</html>