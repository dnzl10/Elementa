<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        
        #sidebar { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        
        @media (max-width: 768px) {
            .sidebar-collapsed { transform: translateX(-100%); }
            .sidebar-open { transform: translateX(0); }
        }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .glass-effect {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <div class="flex min-h-screen relative overflow-x-hidden">
        <div id="sidebarOverlay" onclick="toggleSidebar()" class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden"></div>

        <aside id="sidebar" class="bg-slate-900 text-white w-64 flex-shrink-0 flex flex-col z-50 fixed inset-y-0 left-0 sidebar-collapsed md:translate-x-0 h-screen">
            <div class="p-6 flex items-center justify-between">
                <h1 class="text-xl font-black tracking-tighter text-blue-400">CHEMISTRY ARCADE</h1>
                <button onclick="toggleSidebar()" class="md:hidden text-slate-400 hover:text-white">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <nav class="flex-1 px-4 space-y-2 mt-4 overflow-y-auto no-scrollbar">
                <a href="/home" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-chart-line w-5"></i> Home
                </a>
                <a href="/dashboard" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-house w-5"></i> <span class="font-semibold">Dashboard</span>
                </a>
                <a href="/events" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fa-solid fa-calendar-days text-lg"></i> <span class="font-semibold">Events</span>
                </a>
                <a href="/subjects" class="flex items-center gap-3 p-3 rounded-xl bg-blue-600 text-white font-bold shadow-lg shadow-blue-900/50">
                    <i class="fas fa-book w-5"></i> <span class="font-semibold">Subjects</span>
                </a>
                <a href="/leaderboards" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-trophy w-5 text-yellow-500"></i> <span class="font-semibold">Leaderboards</span>
                </a>
                <a href="/forums" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-comments w-5 text-emerald-500"></i> <span class="font-semibold">Forums</span>
                </a>
            </nav>

            <div class="p-4 border-t border-slate-800">
                <a href="/logout" class="flex items-center gap-3 p-3 rounded-xl text-red-400 hover:bg-red-500/10 transition group">
                    <i class="fas fa-right-from-bracket w-5 group-hover:translate-x-1 transition-transform"></i> 
                    <span class="font-bold">Log Out</span>
                </a>
            </div>
        </aside>

        <main id="mainContent" class="flex-1 flex flex-col min-w-0 md:ml-64 transition-all duration-300">
            <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-40">
                <div class="flex items-center gap-4">
                    <button onclick="toggleSidebar()" class="p-2 rounded-lg hover:bg-slate-100 text-slate-600 md:hidden">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <div class="relative hidden sm:block w-64 lg:w-96">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input type="text" placeholder="Search learning_materials..." class="w-full pl-12 pr-4 py-2 bg-slate-100 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm transition-all">
                    </div>
                </div>

                <div class="flex items-center gap-3 md:gap-6">
                    <div onclick="toggleNotifications()" class="relative group cursor-pointer p-2 hover:bg-slate-100 rounded-full transition">
                        <i class="far fa-bell text-xl text-slate-600"></i>
                        
                        <span class="absolute top-2 right-2 flex h-2.5 w-2.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500 border-2 border-white"></span>
                        </span>

                        <span class="absolute top-12 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-all bg-slate-800 text-white text-[10px] px-2 py-1 rounded">
                            Notifications
                        </span>
                    </div>
                    
                    <div class="relative">
                        <div onclick="toggleUserMenu(event)" id="userMenuBtn" class="flex items-center gap-3 pl-4 border-l border-slate-200 cursor-pointer hover:opacity-80 transition">
                            <div class="text-right hidden lg:block">
                                <p class="text-sm font-bold text-slate-800 leading-none mb-1"><%= user.first_name %> <%= user.last_name %></p>
                                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-widest leading-none"><%= user.role %></p>
                            </div>
                            <img src="<%= user.profile_pic ? '/profile_uploads/' + user.profile_pic : '/profile_uploads/default_avatar.png' %>" class="w-10 h-10 rounded-xl object-cover ring-2 ring-blue-100">
                            <i class="fas fa-chevron-down text-[10px] text-slate-400 ml-1"></i>
                        </div>

                        <div id="userDropdown" class="hidden absolute right-0 mt-3 w-56 bg-white rounded-2xl shadow-xl border border-slate-100 py-2 z-50">
                            <div class="px-4 py-3 border-b border-slate-50 lg:hidden">
                                <p class="text-sm font-bold text-slate-800"><%= user.first_name %></p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase"><%= user.role %></p>
                            </div>
                            <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-user w-5 text-center"></i> View Profile
                            </a>
                            <a href="/settings" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-gear w-5 text-center"></i> Account Settings
                            </a>

                            <a href="/inbox" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-envelope w-5 text-center"></i> Inbox
                            </a>

                            <a href="/scores" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-star w-5 text-center"></i> Scores / Progress
                            </a>

                            <hr class="my-2 border-slate-50">
                            <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-500 hover:bg-red-50 transition font-bold">
                                <i class="fas fa-sign-out-alt w-5 text-center"></i> Log Out
                            </a>
                        </div>
                    </div>
                </div>
            </header>

            <div class="p-4 md:p-8 space-y-8">
                <div class="relative rounded-3xl overflow-hidden bg-white shadow-sm border border-slate-200">
                    <div class="h-48 md:h-64 bg-slate-200 relative">
                        <img src="/profile_uploads/<%= subject.subject_image %>" class="w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
                        <div class="absolute bottom-6 left-8 text-white">
                            <span class="px-3 py-1 bg-blue-500 rounded-full text-[10px] font-black tracking-widest uppercase"><%= subject.subject_code %></span>
                            <h2 class="text-3xl font-black mt-2 tracking-tight"><%= subject.subject_name %></h2>
                            <p class="text-slate-300 text-sm mt-1 font-medium"><%= subject.class_name %> • SY <%= subject.sy_range %></p>
                        </div>
                    </div>
                    
                    <div class="p-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <div class="lg:col-span-2">
                            <h3 class="text-sm font-black text-slate-400 uppercase tracking-widest mb-3">About this Subject</h3>
                            <p class="text-slate-600 leading-relaxed"><%= subject.description %></p>
                        </div>
                        <div class="space-y-6">
                            <div>
                                <h3 class="text-sm font-black text-slate-400 uppercase tracking-widest mb-3">Teacher</h3>
                                <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-50 border border-slate-100">
                                    <img src="/profile_uploads/<%= subject.teacher_pic %>" class="w-10 h-10 rounded-full object-cover ring-2 ring-white">
                                    <div>
                                        <p class="text-sm font-bold text-slate-800"><%= subject.teacher_name %></p>
                                        <p class="text-[10px] text-slate-500">Subject Specialist</p>
                                    </div>
                                </div>
                            </div>
                            <div class="bg-blue-600 rounded-2xl p-4 text-white">
                                <h3 class="text-xs font-black uppercase tracking-widest mb-3 flex justify-between">
                                    Top Rankings <i class="fas fa-trophy text-yellow-400"></i>
                                </h3>
                                <div class="space-y-2">
                                    <% leaderboard.slice(0, 3).forEach((rank, index) => { %>
                                        <div class="flex items-center justify-between text-xs bg-white/10 p-2 rounded-lg">
                                            <span class="font-bold">#<%= index + 1 %> <%= rank.first_name %></span>
                                            <span class="font-mono"><%= rank.total_exp %> EXP</span>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <h2 class="text-xl font-black text-slate-800 flex items-center gap-3">
                        <i class="fas fa-layer-group text-blue-500"></i> Learning Path
                    </h2>

                    <% quarters.forEach((quarter, qIndex) => { %>
                        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm mb-4">
                            <button onclick="document.getElementById('q-<%= quarter.quarter_id %>').classList.toggle('hidden')" 
                                    class="w-full px-6 py-4 flex items-center justify-between hover:bg-slate-50 transition">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center font-black">
                                        <%= quarter.quarter_number %>
                                    </div>
                                    <div class="text-left">
                                        <h4 class="font-bold text-slate-800">Quarter <%= quarter.quarter_number %></h4>
                                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wider">
                                            <%= quarter.topics ? quarter.topics.length : 0 %> Topics Available
                                        </p>
                                    </div>
                                </div>
                                <i class="fas fa-chevron-down text-slate-400 text-sm"></i>
                            </button>

                            <div id="q-<%= quarter.quarter_id %>" class="<%= qIndex === 0 ? '' : 'hidden' %> border-t border-slate-100 p-6 space-y-6 bg-slate-50/30">
                                <% if (quarter.topics && quarter.topics.length > 0) { %>
                                    <% quarter.topics.forEach(topic => { %>
                                        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
                                            <h5 class="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2">
                                                <span class="w-2 h-6 bg-blue-500 rounded-full"></span>
                                                <%= topic.topic_name %>
                                                <% if(topic.is_locked) { %> 
                                                    <i class="fas fa-lock text-slate-300 text-xs ml-2"></i> 
                                                <% } %>
                                            </h5>

                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                                <div class="lg:col-span-1">
                                                    <div class="space-y-6 sticky top-24 overflow-y-auto max-h-[calc(100vh-6rem)]">
                                                        
                                                        <!-- Announcements for this topic -->
                                                        <div class="bg-white rounded-2xl p-4 border border-slate-200 shadow-sm mb-4">
                                                            <h6 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">
                                                                Announcements
                                                            </h6>
                                                            <% if(topic.announcements && topic.announcements.length > 0) { %>
                                                                <% topic.announcements.forEach(ann => { %>
                                                                    <div class="p-2 border-b border-slate-100 text-sm text-slate-700">
                                                                        <p class="font-bold"><%= ann.title %></p>
                                                                        <p class="text-[10px] text-slate-500">
                                                                            <%= new Date(ann.created_at).toLocaleString('en-PH', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                                                            <% if (ann.author_name) { %> • By <%= ann.author_name %><% } %>
                                                                        </p>
                                                                        <p><%= ann.content %></p>
                                                                    </div>
                                                                <% }) %>
                                                            <% } else { %>
                                                                <p class="text-slate-400 italic text-sm">No announcements yet.</p>
                                                            <% } %>
                                                        </div>

                                                        <!-- Forums for this topic -->
                                                        <div class="bg-white rounded-2xl p-4 border border-slate-200 shadow-sm mb-4">
                                                            <h6 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">
                                                                Forums
                                                            </h6>
                                                            <% if(topic.forums && topic.forums.length > 0) { %>
                                                                <% topic.forums.forEach(forum => { 
                                                                    const forumLocked = topic.is_locked || !forum.is_unlocked;
                                                                %>
                                                                <div class="flex justify-between items-center p-2 border-b border-slate-100 text-sm <%= forumLocked ? 'grayscale opacity-60' : '' %>">
                                                                    <div>
                                                                        <p class="font-bold text-slate-800"><%= forum.title %></p>
                                                                        <p class="text-[10px] text-slate-500">
                                                                            By <%= forum.author_name %> • 
                                                                            <%= new Date(forum.created_at).toLocaleString('en-PH', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                                                        </p>
                                                                    </div>
                                                                    <% if(!forumLocked) { %>
                                                                        <button 
                                                                            class="px-3 py-1 text-[10px] font-bold rounded-lg transition"
                                                                            style="background-color: <%= forum.is_done ? '#34D399' : '#FACC15' %>; color:white;"
                                                                            onclick="toggleForumDone(<%= forum.forum_id %>)">
                                                                            <%= forum.is_done ? 'Done' : 'Not Done' %>
                                                                        </button>
                                                                    <% } else { %>
                                                                        <i class="fas fa-lock text-slate-400 text-xs"></i>
                                                                    <% } %>
                                                                </div>
                                                                <% }) %>
                                                            <% } else { %>
                                                                <p class="text-slate-400 italic text-sm">No forum posts yet.</p>
                                                            <% } %>
                                                        </div>

                                                    </div>
                                                </div>
                                                    

                                                <div class="lg:col-span-2 space-y-4">
                                                    <h6 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Resources & Tasks</h6>
                                                    
                                                    <div class="flex flex-wrap gap-2">
                                                        <% if(topic.materials && topic.materials.length > 0) { %>
                                                            <% topic.materials.forEach((mat, matIndex) => { %>
                                                                <button onclick="openPreview('<%= mat.material_type %>', '<%= mat.file_path_or_url %>', '<%= mat.title %>')" 
                                                                        class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 hover:border-blue-500 hover:text-blue-600 transition bg-white group">
                                                                    
                                                                    <% if(mat.material_type === 'pdf') { %> <i class="fas fa-file-pdf text-red-500"></i> <% } 
                                                                    else if(mat.material_type === 'video') { %> <i class="fas fa-play-circle text-blue-500"></i> <% }
                                                                    else if(mat.material_type === 'img') { %> <i class="fas fa-image text-emerald-500"></i> <% }
                                                                    else if(mat.material_type === 'word') { %> <i class="fas fa-file-word text-blue-700"></i> <% }
                                                                    else if(mat.material_type === 'ppt') { %> <i class="fas fa-file-powerpoint text-orange-500"></i> <% }
                                                                    else { %> <i class="fas fa-link text-slate-400"></i> <% } %>

                                                                    <span class="text-xs font-bold"><%= mat.title %></span>
                                                                </button>
                                                            <% }) %>
                                                        <% } %>
                                                    </div>
                                                    
                                                    <div class="space-y-2">
                                                        <% if(topic.assessments && topic.assessments.length > 0) { %>
                                                            <% topic.assessments.forEach(ass => { 
                                                                const assLocked = topic.is_locked || ass.is_unlocked != 1;
                                                            %>
                                                            <div class="flex justify-between items-start p-4 rounded-xl border <%= assLocked ? 'border-slate-100 bg-slate-100 grayscale opacity-60' : 'border-blue-100 bg-blue-50/30' %> transition-all">
                                                                <div>
                                                                    <p class="font-bold text-sm text-slate-800"><%= ass.assessment_name %></p>
                                                                    <p class="text-[10px] text-slate-500 font-bold"><%= ass.assessment_type %> • <%= ass.total_items %> Items</p>
                                                                </div>
                                                                <% if(!assLocked) { %>
                                                                    <button 
                                                                        class="px-3 py-1 rounded-lg text-[10px] font-bold text-white"
                                                                        style="background-color: <%= ass.is_done ? '#34D399' : '#FACC15' %>;"
                                                                        onclick="toggleAssessmentDone(<%= ass.assessment_id %>)">
                                                                        <%= ass.is_done ? 'Done' : 'Not Done' %>
                                                                    </button>
                                                                <% } else { %>
                                                                    <i class="fas fa-lock text-slate-400 text-xs mt-1"></i>
                                                                <% } %>
                                                            </div>
                                                            <% }) %>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="text-center text-slate-400 text-sm py-4 italic">No topics available for this quarter yet.</p>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Preview Modal -->
            <div id="previewModal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center">
                <div class="bg-white rounded-2xl w-11/12 md:w-3/4 lg:w-1/2 overflow-hidden relative shadow-lg">
                    <div class="flex justify-between items-center p-4 border-b border-slate-200">
                        <h4 id="previewTitle" class="font-bold text-slate-800 text-lg">Preview</h4>
                        <button onclick="closePreview()" class="text-slate-500 hover:text-slate-800"><i class="fas fa-times"></i></button>
                    </div>
                    <div id="previewContent" class="p-4 max-h-[70vh] overflow-auto flex justify-center items-center">
                        <!-- Preview content injected here -->
                    </div>
                    <div class="flex justify-end gap-2 p-4 border-t border-slate-200">
                        <a id="downloadBtn" href="#" download class="px-3 py-1 bg-blue-600 text-white rounded-lg font-bold hover:bg-blue-700 transition">Save</a>
                        <button onclick="openFullScreen()" class="px-3 py-1 bg-slate-600 text-white rounded-lg font-bold hover:bg-slate-700 transition">Full Screen</button>
                    </div>
                </div>
            </div>

            </div> <div id="notification-overlay" 
                onclick="toggleNotifications()" 
                class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[60] hidden transition-opacity duration-300 opacity-0">
            </div>

            <div id="notification-panel" 
                class="fixed top-0 right-0 h-screen w-80 md:w-96 bg-white shadow-2xl z-[70] transform translate-x-full transition-transform duration-300 ease-in-out border-l border-slate-200 flex flex-col">
                
                <div class="p-5 border-b flex justify-between items-center bg-blue-600 text-white flex-shrink-0">
                    <h2 class="text-lg font-bold flex items-center gap-2">
                        <i class="far fa-bell"></i> Notifications
                    </h2>
                    <button onclick="toggleNotifications()" class="hover:bg-blue-700 p-2 rounded-lg transition">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50 no-scrollbar" id="notification-list">
                    <div id="notification-loader" class="flex flex-col items-center justify-center h-full text-slate-400">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mb-2"></div>
                        <p class="text-xs font-bold uppercase tracking-wider">Loading Arcade Updates...</p>
                    </div>
                </div>
            </div>
            
            <footer class="mt-auto py-6 px-8 border-t border-slate-200 bg-white/50">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                        <div class="text-center md:text-left">
                            <p class="text-sm text-slate-500 font-medium">
                                &copy; 2026 <span class="text-blue-600 font-bold">Mabini College</span>. All rights reserved.
                            </p>
                            <p class="text-[10px] text-slate-400 uppercase tracking-widest mt-1">
                                System Version 2.4.0-stable
                            </p>
                        </div>

                        <div class="flex flex-wrap justify-center gap-6">
                            <a href="/privacy" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition">Privacy Policy</a>
                            <a href="/terms" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition">Terms of Service</a>
                            <a href="/support" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition flex items-center gap-1">
                                <i class="far fa-question-circle"></i> Help & Support
                            </a>
                        </div>
                    </div>
                </footer>
        </main>
    </div>

    <script>
        async function toggleNotifications() {
            const panel = document.getElementById('notification-panel');
            const overlay = document.getElementById('notification-overlay');
            const list = document.getElementById('notification-list');

            if (panel.classList.contains('translate-x-full')) {
                // OPEN PANEL
                panel.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);

                // FETCH DATA FROM DATABASE
                try {
                    const response = await fetch('/api/notifications'); 
                    const notifications = await response.json();

                    list.innerHTML = '';

                    if (notifications.length === 0) {
                        list.innerHTML = `
                            <div class="flex flex-col items-center justify-center h-64 text-gray-400">
                                <i class="fas fa-check-circle text-4xl mb-2 opacity-20"></i>
                                <p>All caught up!</p>
                            </div>`;
                        return;
                    }

                    notifications.forEach(notif => {
                        const timeAgo = formatTimeAgo(notif.created_at);
                        
                        // --- DYNAMIC CONFIGURATION BASED ON TYPE ---
                        let config = {
                            icon: 'fa-info-circle',
                            border: 'border-gray-500',
                            badge: 'bg-gray-100 text-gray-600',
                            label: notif.type
                        };

                        switch(notif.type) {
                            case 'announcement':
                                config = { icon: 'fa-bullhorn', border: 'border-blue-500', badge: 'bg-blue-100 text-blue-600', label: 'Announcement' };
                                break;
                            case 'assessment':
                                config = { icon: 'fa-file-alt', border: 'border-red-500', badge: 'bg-red-100 text-red-600', label: 'Assessment' };
                                break;
                            case 'material':
                                config = { icon: 'fa-book', border: 'border-purple-500', badge: 'bg-purple-100 text-purple-600', label: 'New Material' };
                                break;
                            case 'forum_new':
                            case 'forum_reply':
                                config = { icon: 'fa-comments', border: 'border-green-500', badge: 'bg-green-100 text-green-600', label: 'Forum' };
                                break;
                            case 'score':
                                config = { icon: 'fa-star', border: 'border-yellow-500', badge: 'bg-yellow-100 text-yellow-700', label: 'Result' };
                                break;
                        }

                        // --- BUILD EXTRA INFO (EXP GAINED / SUBJECT NAME) ---
                        let extraBadge = '';
                        if (notif.extra_info) {
                            const isExp = notif.extra_info.includes('EXP');
                            extraBadge = `<span class="mt-1 inline-block px-2 py-0.5 rounded text-[10px] font-bold ${isExp ? 'bg-green-500 text-white' : 'bg-slate-200 text-slate-700'}">${notif.extra_info}</span>`;
                        }

                        const itemHTML = `
                            <div class="bg-white p-3 rounded-lg border-l-4 ${config.border} shadow-sm hover:shadow-md transition-all cursor-pointer group">
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-[9px] font-bold uppercase px-1.5 py-0.5 rounded ${config.badge}">
                                        <i class="fas ${config.icon} mr-1"></i>${config.label}
                                    </span>
                                    <span class="text-[10px] text-gray-400 group-hover:text-gray-600">${timeAgo}</span>
                                </div>
                                <p class="text-sm font-bold text-gray-800 leading-tight">${notif.heading}</p>
                                <p class="text-xs text-gray-500 mt-0.5 line-clamp-2">${notif.snippet}</p>
                                ${extraBadge}
                            </div>
                        `;
                        list.insertAdjacentHTML('beforeend', itemHTML);
                    });

                } catch (err) {
                    list.innerHTML = `<p class="text-center text-red-500 p-4">Failed to load notifications.</p>`;
                    console.error(err);
                }
            } else {
                // CLOSE PANEL
                panel.classList.add('translate-x-full');
                overlay.classList.remove('opacity-100');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        function formatTimeAgo(dateString) {
            if (!dateString) return '';
            const now = new Date();
            const past = new Date(dateString);
            const diffInMs = now - past;
            const diffInMins = Math.floor(diffInMs / 60000);
            
            if (diffInMins < 0) return 'Upcoming'; // For future due dates
            if (diffInMins < 1) return 'Just now';
            if (diffInMins < 60) return `${diffInMins}m ago`;
            const diffInHours = Math.floor(diffInMins / 60);
            if (diffInHours < 24) return `${diffInHours}h ago`;
            return past.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            
            if (window.innerWidth < 768) {
                sidebar.classList.toggle('sidebar-collapsed');
                sidebar.classList.toggle('sidebar-open');
                overlay.classList.toggle('hidden');
            } else {
                // For desktop, usually you'd toggle a mini-sidebar or just leave it
                sidebar.classList.toggle('sidebar-collapsed');
                document.getElementById('mainContent').classList.toggle('md:ml-64');
                document.getElementById('mainContent').classList.toggle('md:ml-0');
            }
        }

        function toggleUserMenu(event) {
            event.stopPropagation();
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('hidden');
        }

        // Close dropdown when clicking outside
        window.addEventListener('click', function() {
            const dropdown = document.getElementById('userDropdown');
            if (!dropdown.classList.contains('hidden')) {
                dropdown.classList.add('hidden');
            }
        });

        // Auto-handle sidebar on resize
        window.addEventListener('resize', () => {
            const sidebar = document.getElementById('sidebar');
            const main = document.getElementById('mainContent');
            if (window.innerWidth >= 768) {
                sidebar.classList.remove('sidebar-collapsed', 'sidebar-open');
                main.classList.add('md:ml-64');
            } else {
                sidebar.classList.add('sidebar-collapsed');
                main.classList.remove('md:ml-64');
            }
        });

        function openPreview(type, filePath, title) {
        const modal = document.getElementById('previewModal');
        const content = document.getElementById('previewContent');
        const titleEl = document.getElementById('previewTitle');
        const downloadBtn = document.getElementById('downloadBtn');

        titleEl.textContent = title;
        downloadBtn.href = '/profile_uploads/' + filePath;

        let html = '';

        switch(type) {
            case 'pdf':
                html = `<iframe src="/profile_uploads/${filePath}" class="w-full h-[60vh]" frameborder="0"></iframe>`;
                break;
            case 'video':
                html = `<video src="/profile_uploads/${filePath}" controls class="w-full h-[60vh]"></video>`;
                break;
            case 'img':
                html = `<img src="/profile_uploads/${filePath}" class="max-h-[60vh] object-contain" />`;
                break;
            case 'word':
            case 'ppt':
                html = `<iframe src="https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(window.location.origin + '/profile_uploads/' + filePath)}" class="w-full h-[60vh]" frameborder="0"></iframe>`;
                break;
            case 'link':
                html = `<iframe src="${filePath}" class="w-full h-[60vh]" frameborder="0"></iframe>`;
                break;
            default:
                html = `<p class="text-red-500">Cannot preview this file type</p>`;
        }

        content.innerHTML = html;
        modal.classList.remove('hidden');
    }

    function closePreview() {
        document.getElementById('previewModal').classList.add('hidden');
        document.getElementById('previewContent').innerHTML = '';
    }

    function openFullScreen() {
        const iframe = document.querySelector('#previewContent iframe, #previewContent video, #previewContent img');
        if (iframe) {
            if (iframe.requestFullscreen) iframe.requestFullscreen();
            else if (iframe.webkitRequestFullscreen) iframe.webkitRequestFullscreen();
            else if (iframe.msRequestFullscreen) iframe.msRequestFullscreen();
        }
    }
    </script>
</body>
</html>