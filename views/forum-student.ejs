<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        
        #sidebar { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        
        @media (max-width: 768px) {
            .sidebar-collapsed { transform: translateX(-100%); }
            .sidebar-open { transform: translateX(0); }
        }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .glass-effect {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
        }

        @keyframes slide-in {
                    from { transform: translateX(100%); }
                    to { transform: translateX(0); }
                }
                .animate-slide-in { animation: slide-in 0.3s ease-out; }

        @keyframes fade-in {
                    from { opacity: 0; transform: scale(0.95); }
                    to { opacity: 1; transform: scale(1); }
                }
                .animate-fade-in {
                    animation: fade-in 0.2s ease-out;
                }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <div class="flex min-h-screen relative overflow-x-hidden">
        <div id="sidebarOverlay" onclick="toggleSidebar()" class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden"></div>

        <aside id="sidebar" class="bg-slate-900 text-white w-64 flex-shrink-0 flex flex-col z-50 fixed inset-y-0 left-0 sidebar-collapsed md:translate-x-0 h-screen">
            <div class="p-6 flex items-center justify-between">
                <h1 class="text-xl font-black tracking-tighter text-blue-400">CHEMISTRY ARCADE</h1>
                <button onclick="toggleSidebar()" class="md:hidden text-slate-400 hover:text-white">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <nav class="flex-1 px-4 space-y-2 mt-4 overflow-y-auto no-scrollbar">
                <a href="/home" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-house w-5"></i> Home
                </a>
                <a href="/dashboard" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-chart-line w-5"></i> <span class="font-semibold">Dashboard</span>
                </a>
                <a href="/events" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fa-solid fa-calendar-days text-lg"></i> <span class="font-semibold">Events</span>
                </a>
                <a href="/subjects" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-book w-5"></i> <span class="font-semibold">Subjects</span>
                </a>
                <a href="/leaderboards" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-trophy w-5 text-yellow-500"></i> <span class="font-semibold">Leaderboards</span>
                </a>
                <a href="/forums" class="flex items-center gap-3 p-3 rounded-xl bg-blue-600 text-white font-bold shadow-lg shadow-blue-900/50">
                    <i class="fas fa-comments w-5 text-emerald-500"></i> <span class="font-semibold">Forums</span>
                </a>
            </nav>

            <div class="p-4 border-t border-slate-800">
                <a href="/logout" class="flex items-center gap-3 p-3 rounded-xl text-red-400 hover:bg-red-500/10 transition group">
                    <i class="fas fa-right-from-bracket w-5 group-hover:translate-x-1 transition-transform"></i> 
                    <span class="font-bold">Log Out</span>
                </a>
            </div>
        </aside>

        <main id="mainContent" class="flex-1 flex flex-col min-w-0 md:ml-64 transition-all duration-300">
            <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-40">
                <div class="flex items-center gap-4">
                    <button onclick="toggleSidebar()" class="p-2 rounded-lg hover:bg-slate-100 text-slate-600 md:hidden">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <div class="relative hidden sm:block w-64 lg:w-96">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input type="text" placeholder="Search Materials..." class="w-full pl-12 pr-4 py-2 bg-slate-100 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm transition-all">
                    </div>
                </div>

                <div class="flex items-center gap-3 md:gap-6">
                    <div onclick="toggleNotifications()" class="relative group cursor-pointer p-2 hover:bg-slate-100 rounded-full transition">
                        <i class="far fa-bell text-xl text-slate-600"></i>
                        
                        <span class="absolute top-2 right-2 flex h-2.5 w-2.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500 border-2 border-white"></span>
                        </span>

                        <span class="absolute top-12 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-all bg-slate-800 text-white text-[10px] px-2 py-1 rounded">
                            Notifications
                        </span>
                    </div>
                    
                    <div class="relative">
                        <div onclick="toggleUserMenu(event)" id="userMenuBtn" class="flex items-center gap-3 pl-4 border-l border-slate-200 cursor-pointer hover:opacity-80 transition">
                            <div class="text-right hidden lg:block">
                                <p class="text-sm font-bold text-slate-800 leading-none mb-1"><%= user.first_name %> <%= user.last_name %></p>
                                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-widest leading-none"><%= user.role %></p>
                            </div>
                            <img src="<%= user.profile_pic ? '/profile_uploads/' + user.profile_pic : '/profile_uploads/default_avatar.png' %>" class="w-10 h-10 rounded-xl object-cover ring-2 ring-blue-100">
                            <i class="fas fa-chevron-down text-[10px] text-slate-400 ml-1"></i>
                        </div>

                        <div id="userDropdown" class="hidden absolute right-0 mt-3 w-56 bg-white rounded-2xl shadow-xl border border-slate-100 py-2 z-50">
                            <div class="px-4 py-3 border-b border-slate-50 lg:hidden">
                                <p class="text-sm font-bold text-slate-800"><%= user.first_name %></p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase"><%= user.role %></p>
                            </div>
                            <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-user w-5 text-center"></i> View Profile
                            </a>
                            <a href="/settings" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-gear w-5 text-center"></i> Account Settings
                            </a>

                            <a href="/inbox" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-envelope w-5 text-center"></i> Inbox
                            </a>

                            <a href="/scores" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-star w-5 text-center"></i> Scores / Progress
                            </a>

                            <hr class="my-2 border-slate-50">
                            <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-500 hover:bg-red-50 transition font-bold">
                                <i class="fas fa-sign-out-alt w-5 text-center"></i> Log Out
                            </a>
                        </div>
                    </div>
                </div>
            </header>

            <div class="flex-1 flex flex-col md:flex-row min-h-0 overflow-hidden h-[calc(100vh-80px)]">
                <aside class="w-full md:w-80 bg-white border-r border-slate-200 overflow-y-auto p-6 space-y-8">
                    <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-3xl p-5 text-white shadow-lg">
                        <p class="text-[10px] font-bold opacity-70 uppercase tracking-widest mb-1">Activity Rank</p>
                        <p class="text-3xl font-black"><%= totalParticipated %></p>
                        <p class="text-xs opacity-80">Discussions Joined</p>
                        <div class="mt-4 pt-4 border-t border-white/10 flex items-center gap-2">
                            <i class="fas fa-award text-yellow-400"></i>
                            <span class="text-[10px] font-bold uppercase"><%= totalParticipated >= 5 ? 'Active Alchemist' : 'Novice' %></span>
                        </div>
                    </div>

                    <nav class="space-y-4">
                        <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-2">Subjects</h4>
                        <div class="space-y-1">
                            <button onclick="filterForum('all')" class="w-full flex items-center gap-3 p-3 rounded-xl bg-blue-50 text-blue-600 font-bold">
                                <i class="fas fa-globe"></i> Global Square
                            </button>
                            <% forums.forEach(s => { %>
                                <button onclick="filterForum('<%= s.subject_id %>')" class="w-full flex items-center gap-3 p-3 rounded-xl text-slate-500 hover:bg-slate-50 font-semibold transition">
                                    <i class="fas fa-flask text-emerald-500"></i> <%= s.subject_name %>
                                </button>
                            <% }) %>
                        </div>
                    </nav>
                </aside>

                <section class="flex-1 bg-slate-50/50 overflow-y-auto p-4 md:p-8 no-scrollbar">
                    <div class="mb-8">
                        <h2 class="text-2xl font-black text-slate-800 tracking-tight">Chemistry Commons</h2>
                        <p class="text-sm text-slate-500">Engage with your professors and peers.</p>
                    </div>

                    <div id="forumList" class="space-y-4">
                        <% forums.forEach(forum => { %>
                            <div class="forum-card bg-white p-5 rounded-3xl border border-slate-200 shadow-sm hover:shadow-md transition-all" data-subject="<%= forum.subject_id || 'all' %>">
                                <div class="flex flex-col md:flex-row gap-4 justify-between">
                                    <div class="flex gap-4">
                                        <img src="/profile_uploads/<%= forum.teacher_pic || 'default_avatar.png' %>" class="w-12 h-12 rounded-2xl object-cover ring-4 ring-slate-50">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <% if (forum.is_pinned) { %>
                                                    <span class="bg-amber-100 text-amber-700 text-[9px] font-black px-2 py-0.5 rounded uppercase italic"><i class="fas fa-thumbtack mr-1"></i>Pinned</span>
                                                <% } %>
                                                <% if (forum.is_done) { %>
                                                    <span class="bg-emerald-100 text-emerald-700 text-[9px] font-black px-2 py-0.5 rounded uppercase"><i class="fas fa-check-circle mr-1"></i>Completed</span>
                                                <% } %>
                                                <span class="text-[10px] font-bold text-blue-500 uppercase tracking-wider"><%= forum.topic_name || 'General' %></span>
                                            </div>
                                            <h3 class="font-bold text-slate-800 text-lg leading-tight"><%= forum.title %></h3>
                                            <p class="text-xs text-slate-400 mt-1">Started by <span class="font-bold text-slate-600">Prof. <%= forum.teacher_lname %></span></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-4">
                                        <div class="text-right hidden sm:block">
                                            <p class="text-lg font-black text-slate-800"><%= forum.reply_count %></p>
                                            <p class="text-[10px] text-slate-400 font-bold uppercase">Replies</p>
                                        </div>
                                        <button onclick="openThread('<%= forum.forum_id %>', '<%= forum.title %>')" class="bg-slate-900 text-white px-5 py-2.5 rounded-xl font-bold text-xs hover:bg-blue-600 transition-all">
                                            View Discussion
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </section>
            </div>

            <div id="threadModal" class="fixed inset-0 z-[60] hidden flex items-center justify-center">

                <!-- Overlay -->
                <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeModal()"></div>

                <!-- Modal -->
                <div class="relative w-full max-w-4xl h-[92vh] bg-white rounded-3xl shadow-2xl flex flex-col overflow-hidden animate-fade-in">

                    <!-- HEADER -->
                    <div class="p-6 border-b bg-white flex flex-col gap-1">
                        <h3 id="modalTitle" class="font-black text-2xl text-slate-800"></h3>
                        <p id="threadMeta" class="text-xs text-slate-400 flex items-center gap-2">
                            <i class="fas fa-user text-[10px]"></i>
                            <!-- dynamic -->
                        </p>
                    </div>

                    <!-- SCROLLABLE BODY -->
                    <div class="flex-1 overflow-y-auto bg-slate-50">

                        <div class="px-5 py-4 border-b bg-white">
                            <div class="flex gap-2 items-start">

                                <i class="fas fa-comment-dots text-blue-500 mt-1"></i>

                                <div class="w-full">
                                    <h3 class="text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">
                                        Content
                                    </h3>

                                    <div id="threadContent"
                                        class="text-sm text-slate-700 leading-relaxed whitespace-pre-line break-words
                                            max-h-32 overflow-y-auto pr-2">
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- REPLIES -->
                        <div id="repliesContainer" class="px-8 py-6 space-y-6">
                        </div>

                    </div>

                    <!-- FORM -->
                    <div class="p-5 border-t bg-white">

                        <div id="replyIndicator"
                            class="hidden flex items-center justify-between bg-blue-50 p-3 rounded-xl mb-3 border border-blue-100">
                            <p class="text-xs text-blue-700 font-bold flex items-center gap-2" id="replyTargetText">
                                <i class="fas fa-reply"></i>
                            </p>
                            <button type="button" onclick="cancelReply()" class="text-blue-700 hover:text-red-500">
                                ✕
                            </button>
                        </div>

                        <form id="replyForm" class="space-y-3" enctype="multipart/form-data">
                            <input type="hidden" id="activeForumId" name="forum_id"> 

                            <textarea id="replyContent" name="reply_text" required
                                placeholder="Write your insight..."
                                class="w-full p-4 bg-slate-100 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none resize-none"
                                rows="3"></textarea>

                            <input type="file" id="replyFile" name="file"
                                class="w-full text-xs text-slate-500">

                            <button type="submit"
                                class="w-full py-3 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 transition flex items-center justify-center gap-2">
                                <i class="fas fa-paper-plane"></i> Post Insight
                            </button>
                        </form>
                    </div>

                </div>
            </div>


            </div> <div id="notification-overlay" 
                onclick="toggleNotifications()" 
                class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[60] hidden transition-opacity duration-300 opacity-0">
            </div>

            <div id="notification-panel" 
                class="fixed top-0 right-0 h-screen w-80 md:w-96 bg-white shadow-2xl z-[70] transform translate-x-full transition-transform duration-300 ease-in-out border-l border-slate-200 flex flex-col">
                
                <div class="p-5 border-b flex justify-between items-center bg-blue-600 text-white flex-shrink-0">
                    <h2 class="text-lg font-bold flex items-center gap-2">
                        <i class="far fa-bell"></i> Notifications
                    </h2>
                    <button onclick="toggleNotifications()" class="hover:bg-blue-700 p-2 rounded-lg transition">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50 no-scrollbar" id="notification-list">
                    <div id="notification-loader" class="flex flex-col items-center justify-center h-full text-slate-400">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mb-2"></div>
                        <p class="text-xs font-bold uppercase tracking-wider">Loading Arcade Updates...</p>
                    </div>
                </div>
            </div>

            

            <footer class="mt-auto py-6 px-8 border-t border-slate-200 bg-white/50">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                        <div class="text-center md:text-left">
                            <p class="text-sm text-slate-500 font-medium">
                                &copy; 2026 <span class="text-blue-600 font-bold">Mabini College</span>. All rights reserved.
                            </p>
                            <p class="text-[10px] text-slate-400 uppercase tracking-widest mt-1">
                                System Version 2.4.0-stable
                            </p>
                        </div>

                        <div class="flex flex-wrap justify-center gap-6">
                            <a href="/privacy" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition">Privacy Policy</a>
                            <a href="/terms" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition">Terms of Service</a>
                            <a href="/support" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition flex items-center gap-1">
                                <i class="far fa-question-circle"></i> Help & Support
                            </a>
                        </div>
                    </div>
                </footer>
        </main>
    </div>

    <script>

        async function toggleNotifications() {
            const panel = document.getElementById('notification-panel');
            const overlay = document.getElementById('notification-overlay');
            const list = document.getElementById('notification-list');

            if (panel.classList.contains('translate-x-full')) {
                // OPEN PANEL
                panel.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);

                // FETCH DATA FROM DATABASE
                try {
                    const response = await fetch('/api/notifications'); 
                    const notifications = await response.json();

                    list.innerHTML = '';

                    if (notifications.length === 0) {
                        list.innerHTML = `
                            <div class="flex flex-col items-center justify-center h-64 text-gray-400">
                                <i class="fas fa-check-circle text-4xl mb-2 opacity-20"></i>
                                <p>All caught up!</p>
                            </div>`;
                        return;
                    }

                    notifications.forEach(notif => {
                        const timeAgo = formatTimeAgo(notif.created_at);
                        
                        // --- DYNAMIC CONFIGURATION BASED ON TYPE ---
                        let config = {
                            icon: 'fa-info-circle',
                            border: 'border-gray-500',
                            badge: 'bg-gray-100 text-gray-600',
                            label: notif.type
                        };

                        switch(notif.type) {
                            case 'announcement':
                                config = { icon: 'fa-bullhorn', border: 'border-blue-500', badge: 'bg-blue-100 text-blue-600', label: 'Announcement' };
                                break;
                            case 'assessment':
                                config = { icon: 'fa-file-alt', border: 'border-red-500', badge: 'bg-red-100 text-red-600', label: 'Assessment' };
                                break;
                            case 'material':
                                config = { icon: 'fa-book', border: 'border-purple-500', badge: 'bg-purple-100 text-purple-600', label: 'New Material' };
                                break;
                            case 'forum_new':
                            case 'forum_reply':
                                config = { icon: 'fa-comments', border: 'border-green-500', badge: 'bg-green-100 text-green-600', label: 'Forum' };
                                break;
                            case 'score':
                                config = { icon: 'fa-star', border: 'border-yellow-500', badge: 'bg-yellow-100 text-yellow-700', label: 'Result' };
                                break;
                        }

                        // --- BUILD EXTRA INFO (EXP GAINED / SUBJECT NAME) ---
                        let extraBadge = '';
                        if (notif.extra_info) {
                            const isExp = notif.extra_info.includes('EXP');
                            extraBadge = `<span class="mt-1 inline-block px-2 py-0.5 rounded text-[10px] font-bold ${isExp ? 'bg-green-500 text-white' : 'bg-slate-200 text-slate-700'}">${notif.extra_info}</span>`;
                        }

                        const itemHTML = `
                            <div class="bg-white p-3 rounded-lg border-l-4 ${config.border} shadow-sm hover:shadow-md transition-all cursor-pointer group">
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-[9px] font-bold uppercase px-1.5 py-0.5 rounded ${config.badge}">
                                        <i class="fas ${config.icon} mr-1"></i>${config.label}
                                    </span>
                                    <span class="text-[10px] text-gray-400 group-hover:text-gray-600">${timeAgo}</span>
                                </div>
                                <p class="text-sm font-bold text-gray-800 leading-tight">${notif.heading}</p>
                                <p class="text-xs text-gray-500 mt-0.5 line-clamp-2">${notif.snippet}</p>
                                ${extraBadge}
                            </div>
                        `;
                        list.insertAdjacentHTML('beforeend', itemHTML);
                    });

                } catch (err) {
                    list.innerHTML = `<p class="text-center text-red-500 p-4">Failed to load notifications.</p>`;
                    console.error(err);
                }
            } else {
                // CLOSE PANEL
                panel.classList.add('translate-x-full');
                overlay.classList.remove('opacity-100');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        function formatTimeAgo(dateString) {
            if (!dateString) return '';
            const now = new Date();
            const past = new Date(dateString);
            const diffInMs = now - past;
            const diffInMins = Math.floor(diffInMs / 60000);
            
            if (diffInMins < 0) return 'Upcoming'; // For future due dates
            if (diffInMins < 1) return 'Just now';
            if (diffInMins < 60) return `${diffInMins}m ago`;
            const diffInHours = Math.floor(diffInMins / 60);
            if (diffInHours < 24) return `${diffInHours}h ago`;
            return past.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            
            if (window.innerWidth < 768) {
                sidebar.classList.toggle('sidebar-collapsed');
                sidebar.classList.toggle('sidebar-open');
                overlay.classList.toggle('hidden');
            } else {
                sidebar.classList.toggle('sidebar-collapsed');
                document.getElementById('mainContent').classList.toggle('md:ml-64');
                document.getElementById('mainContent').classList.toggle('md:ml-0');
            }
        }

        function toggleUserMenu(event) {
            event.stopPropagation();
            document.getElementById('userDropdown').classList.toggle('hidden');
        }

        window.addEventListener('click', () => {
            const dropdown = document.getElementById('userDropdown');
            if (!dropdown.classList.contains('hidden')) {
                dropdown.classList.add('hidden');
            }
        });

        window.addEventListener('resize', () => {
            const sidebar = document.getElementById('sidebar');
            const main = document.getElementById('mainContent');
            if (window.innerWidth >= 768) {
                sidebar.classList.remove('sidebar-collapsed', 'sidebar-open');
                main.classList.add('md:ml-64');
            } else {
                sidebar.classList.add('sidebar-collapsed');
                main.classList.remove('md:ml-64');
            }
        });

        function filterForum(subjectId, element) {
            const cards = document.querySelectorAll('.forum-card');

            cards.forEach(card => {
                const cardSubject = card.getAttribute('data-subject');
                if (subjectId === 'all' || String(cardSubject) === String(subjectId)) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });

            const navButtons = document.querySelectorAll('nav button');
            navButtons.forEach(btn => {
                btn.className = "w-full flex items-center gap-3 p-3 rounded-xl text-slate-500 hover:bg-slate-50 font-semibold transition";
            });

            if (element) {
                element.className = subjectId === 'all'
                    ? "w-full flex items-center gap-3 p-3 rounded-xl bg-blue-50 text-blue-600 font-black shadow-sm ring-1 ring-blue-100"
                    : "w-full flex items-center gap-3 p-3 rounded-xl bg-emerald-50 text-emerald-600 font-black shadow-sm ring-1 ring-emerald-100";
            }
        }

        let currentForumId = null;
        let refreshTask = null;
        let activeParentId = null;

        // ✅ UPDATED: load thread info (content + created_at)
        async function openThread(id, title) {
            currentForumId = id;
            activeParentId = null;

            document.getElementById('activeForumId').value = id;
            document.getElementById('modalTitle').innerText = title;

            document.getElementById('threadModal').classList.remove('hidden');

            try {
                const res = await fetch(`/api/forum-topic/${id}`);
                const topic = await res.json();

                document.getElementById('threadContent').textContent =
                    (topic.forum_content || '').trim();

            document.getElementById('threadMeta').innerText =
                `Posted on ${new Date(topic.created_at).toLocaleString()
                }`;

            } catch (err) {
                console.error("Error loading topic:", err);
            }

            cancelReply();
            await loadReplies();

            if (refreshTask) clearInterval(refreshTask);
            refreshTask = setInterval(loadReplies, 5000);
        }

        async function loadReplies() {
            if (!currentForumId) return;

            const container = document.getElementById('repliesContainer');

            try {
                const res = await fetch(`/api/forum-replies/${currentForumId}`);
                const data = await res.json();

                container.innerHTML = data.length ? '' :
                    '<div class="text-center py-20 text-slate-400 italic">No insights yet.</div>';

                data.forEach(reply => {
                    const isNested = reply.parent_reply_id !== null;

                    // ✅ Attachment handling
                    let attachmentHTML = '';
                    if (reply.file_path) {
                        attachmentHTML = `
                            <a href="/forum_uploads/${reply.file_path}" download
                            class="text-blue-500 text-xs underline mt-1 block">
                            📎 Download Attachment
                            </a>`;
                    }

                    container.innerHTML += `
                        <div class="flex gap-3 ${isNested ? 'ml-10 border-l-2 pl-4' : ''} mb-4">
                            <img src="/profile_uploads/${reply.profile_pic || 'default_avatar.png'}"
                                class="w-8 h-8 rounded-lg object-cover">

                            <div class="flex-1">
                                <div class="bg-white p-3 rounded-2xl shadow border">
                                    <p class="text-xs font-bold text-blue-600">
                                        ${reply.first_name} ${reply.last_name}
                                    </p>

                                    <div class="w-full">
                                        <p class="text-sm leading-tight break-words text-justify">
                                            ${(reply.reply_content || '')
                                                .trim()
                                                .replace(/\n+/g, '<br>')
                                            }
                                        </p>
                                    </div>

                                    ${attachmentHTML}

                                    <p class="text-[10px] text-gray-400 mt-1">
                                        ${new Date(reply.created_at).toLocaleString()}
                                    </p>
                                </div>

                                <button onclick="setParentReply('${reply.first_name}', ${reply.reply_id})"
                                    class="text-xs text-gray-400 hover:text-blue-600 mt-1">
                                    Reply
                                </button>
                            </div>
                        </div>`;
                });

            } catch (e) {
                console.error("Error loading replies:", e);
            }
        }

        function setParentReply(name, id) {
            activeParentId = id;
            document.getElementById('replyIndicator').classList.remove('hidden');
            document.getElementById('replyTargetText').innerText = `Replying to ${name}`;

            const input = document.getElementById('replyContent');
            input.placeholder = `Reply to ${name}...`;
            input.focus();
        }

        function cancelReply() {
            activeParentId = null;
            document.getElementById('replyIndicator').classList.add('hidden');

            const input = document.getElementById('replyContent');
            input.placeholder = "Write your insight...";
            input.value = "";
        }

        // ✅ UPDATED: FILE UPLOAD SUPPORT
        const replyForm = document.getElementById('replyForm');
        if (replyForm) {
            replyForm.addEventListener('submit', async function(e) {
                e.preventDefault();

                const formData = new FormData();
                const activeForumId = document.getElementById('activeForumId').value;
                const replyContent = document.getElementById('replyContent').value;
                const fileInput = document.getElementById('replyFile');

                formData.append('forum_id', activeForumId);
                formData.append('reply_text', replyContent);
                // Siguraduhing may default value ang activeParentId (e.g., null o "")
                formData.append('parent_id', typeof activeParentId !== 'undefined' ? activeParentId : "");

                if (fileInput.files[0]) {
                    // Siguraduhing 'attachment' o 'file' ang inaasahan ng iyong backend Multer config
                    formData.append('file', fileInput.files[0]);
                }

                try {
                    console.log('Submitting insight...');

                    const res = await fetch('/api/forum-reply', {
                        method: 'POST',
                        body: formData
                    });

                    // STEP 1: Basahin ang response bilang TEXT muna.
                    // Ito ay para hindi mag-error ang stream kahit anong mangyari.
                    const rawResponse = await res.text();
                    let data;

                    // STEP 2: Subukang i-parse ang text bilang JSON.
                    try {
                        data = JSON.parse(rawResponse);
                    } catch (jsonErr) {
                        console.error('Server returned non-JSON response:', rawResponse);
                        throw new Error('Server returned an error page (HTML). Please check the server terminal.');
                    }

                    // STEP 3: Check kung hindi OK ang status o kung may success: false
                    if (!res.ok || !data.success) {
                        console.error('Server error details:', data);
                        throw new Error(data.error || 'Upload failed');
                    }

                    // STEP 4: SUCCESS LOGIC
                    console.log('Upload success:', data);
                    
                    // Reset fields
                    document.getElementById('replyContent').value = '';
                    fileInput.value = '';

                    // Close modal/reply UI and refresh
                    if (typeof cancelReply === 'function') cancelReply();
                    if (typeof loadReplies === 'function') await loadReplies();

                    // Optional: Show success toast/alert
                    // alert('Insight posted successfully!');

                } catch (err) {
                    console.error('Final Catch - Upload error:', err);
                    alert("Error: " + err.message);
                }
            });
        }

        function closeModal() {
            document.getElementById('threadModal').classList.add('hidden');
            clearInterval(refreshTask);
            currentForumId = null;
        }
    </script>
</body>
</html>