<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Chemistry Arcade</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        
        #sidebar { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        
        @media (max-width: 768px) {
            .sidebar-collapsed { transform: translateX(-100%); }
            .sidebar-open { transform: translateX(0); }
        }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .glass-effect {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <div class="flex min-h-screen relative overflow-x-hidden">
        <div id="sidebarOverlay" onclick="toggleSidebar()" class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden"></div>

        <aside id="sidebar" class="bg-slate-900 text-white w-64 flex-shrink-0 flex flex-col z-50 fixed inset-y-0 left-0 sidebar-collapsed md:translate-x-0 h-screen">
            <div class="p-6 flex items-center justify-between">
                <h1 class="text-xl font-black tracking-tighter text-blue-400">CHEMISTRY ARCADE</h1>
                <button onclick="toggleSidebar()" class="md:hidden text-slate-400 hover:text-white">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <nav class="flex-1 px-4 space-y-2 mt-4 overflow-y-auto no-scrollbar">
                <a href="/home" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-house w-5"></i> Home
                </a>
                <a href="/dashboard" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-chart-line w-5"></i> <span class="font-semibold">Dashboard</span>
                </a>
                <a href="/events" class="flex items-center gap-3 p-3 rounded-xl bg-blue-600 text-white font-bold shadow-lg shadow-blue-900/50">
                    <i class="fa-solid fa-calendar-days text-lg"></i> <span class="font-semibold">Events</span>
                </a>
                <a href="/subjects" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-book w-5"></i> <span class="font-semibold">Subjects</span>
                </a>
                <a href="/leaderboards" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-trophy w-5 text-yellow-500"></i> <span class="font-semibold">Leaderboards</span>
                </a>
                <a href="/forums" class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-800 transition text-slate-400 hover:text-white">
                    <i class="fas fa-comments w-5 text-emerald-500"></i> <span class="font-semibold">Forums</span>
                </a>
            </nav>

            <div class="p-4 border-t border-slate-800">
                <a href="/logout" class="flex items-center gap-3 p-3 rounded-xl text-red-400 hover:bg-red-500/10 transition group">
                    <i class="fas fa-right-from-bracket w-5 group-hover:translate-x-1 transition-transform"></i> 
                    <span class="font-bold">Log Out</span>
                </a>
            </div>
        </aside>

        <main id="mainContent" class="flex-1 flex flex-col min-w-0 md:ml-64 transition-all duration-300">
            <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-40">
                <div class="flex items-center gap-4">
                    <button onclick="toggleSidebar()" class="p-2 rounded-lg hover:bg-slate-100 text-slate-600 md:hidden">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <div class="relative hidden sm:block w-64 lg:w-96">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input type="text" placeholder="Search Materials..." class="w-full pl-12 pr-4 py-2 bg-slate-100 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm transition-all">
                    </div>
                </div>

                <div class="flex items-center gap-3 md:gap-6">
                    <div onclick="toggleNotifications()" class="relative group cursor-pointer p-2 hover:bg-slate-100 rounded-full transition">
                        <i class="far fa-bell text-xl text-slate-600"></i>
                        
                        <span class="absolute top-2 right-2 flex h-2.5 w-2.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500 border-2 border-white"></span>
                        </span>

                        <span class="absolute top-12 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-all bg-slate-800 text-white text-[10px] px-2 py-1 rounded">
                            Notifications
                        </span>
                    </div>
                    
                    <div class="relative">
                        <div onclick="toggleUserMenu(event)" id="userMenuBtn" class="flex items-center gap-3 pl-4 border-l border-slate-200 cursor-pointer hover:opacity-80 transition">
                            <div class="text-right hidden lg:block">
                                <p class="text-sm font-bold text-slate-800 leading-none mb-1"><%= user.first_name %> <%= user.last_name %></p>
                                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-widest leading-none"><%= user.role %></p>
                            </div>
                            <img src="<%= user.profile_pic ? '/profile_uploads/' + user.profile_pic : '/profile_uploads/default_avatar.png' %>" class="w-10 h-10 rounded-xl object-cover ring-2 ring-blue-100">
                            <i class="fas fa-chevron-down text-[10px] text-slate-400 ml-1"></i>
                        </div>

                        <div id="userDropdown" class="hidden absolute right-0 mt-3 w-56 bg-white rounded-2xl shadow-xl border border-slate-100 py-2 z-50">
                            <div class="px-4 py-3 border-b border-slate-50 lg:hidden">
                                <p class="text-sm font-bold text-slate-800"><%= user.first_name %></p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase"><%= user.role %></p>
                            </div>
                            <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-user w-5 text-center"></i> View Profile
                            </a>
                            <a href="/settings" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-gear w-5 text-center"></i> Account Settings
                            </a>

                            <a href="/inbox" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-envelope w-5 text-center"></i> Inbox
                            </a>

                            <a href="/scores" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition">
                                <i class="far fa-star w-5 text-center"></i> Scores / Progress
                            </a>

                            <hr class="my-2 border-slate-50">
                            <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-500 hover:bg-red-50 transition font-bold">
                                <i class="fas fa-sign-out-alt w-5 text-center"></i> Log Out
                            </a>
                        </div>
                    </div>
                </div>
            </header>

            <div class="p-4 md:p-8">
                <div class="mb-8">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                        <div>
                            <h2 class="text-3xl font-extrabold text-slate-800 tracking-tight">Calendar & Events</h2>
                            <p class="text-slate-500">Manage your academic schedule and arcade sessions.</p>
                        </div>
                        <div class="flex items-center gap-3">
                                <div class="flex items-center bg-white p-1 rounded-2xl border border-slate-200 shadow-sm mr-2">
                                    <button onclick="switchView('grid')" id="btnGrid" class="px-4 py-2 rounded-xl text-sm font-bold transition-all bg-slate-100 text-blue-600">
                                        <i class="fas fa-th-large mr-2"></i>Grid
                                    </button>
                                    <button onclick="switchView('agenda')" id="btnAgenda" class="px-4 py-2 rounded-xl text-sm font-bold transition-all text-slate-500 hover:bg-slate-50">
                                        <i class="fas fa-list mr-2"></i>Agenda
                                    </button>
                                </div>                                                                                  

                        <button onclick="openEventModal()" class="flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-2xl font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all">
                            <i class="fas fa-plus"></i>
                            New Event
                        </button>
                    </div>
                </div>
            </div>

                    <div id="gridView" class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                            <h3 class="font-bold text-slate-700">
                                <%= new Date().toLocaleString('default', { month: 'long', year: 'numeric' }) %>
                            </h3>
                        </div>

                        <div class="grid grid-cols-7 border-b border-slate-200 bg-slate-50">
                            <% ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].forEach(day => { %>
                                <div class="p-3 text-center text-[10px] font-black uppercase tracking-widest text-slate-400">
                                    <%= day %>
                                </div>
                            <% }) %>
                        </div>

                        <div class="grid grid-cols-7 auto-rows-[120px]">
                            <% 
                                const today = new Date();
                                const year = today.getFullYear();
                                const month = today.getMonth();
                                const firstDayOfMonth = new Date(year, month, 1).getDay();
                                const daysInMonth = new Date(year, month + 1, 0).getDate();
                                const prevMonthLastDay = new Date(year, month, 0).getDate();
                                
                                for (let i = 0; i < firstDayOfMonth; i++) { %>
                                    <div class="border-r border-b border-slate-50 p-2 bg-slate-50/30">
                                        <span class="text-xs font-bold text-slate-300"><%= prevMonthLastDay - firstDayOfMonth + i + 1 %></span>
                                    </div>
                                <% } 

                                for (let day = 1; day <= daysInMonth; day++) { 
                                    const dayEvents = events.filter(e => {
                                        const d = new Date(e.event_date);
                                        return d.getDate() === day && d.getMonth() === month && d.getFullYear() === year;
                                    });
                                %>
                                    <div class="border-r border-b border-slate-100 p-2 hover:bg-slate-50 transition-colors relative group">
                                        <span class="text-xs font-bold <%= (day === today.getDate()) ? 'bg-blue-600 text-white w-6 h-6 flex items-center justify-center rounded-full' : 'text-slate-400' %>">
                                            <%= day %>
                                        </span>
                                        <div class="mt-1 space-y-1 overflow-y-auto max-h-[80px] no-scrollbar">
                                            <% dayEvents.forEach(event => { %>
                                                <div title="<%= event.event_title %>" 
                                                    class="p-1 rounded text-[9px] font-bold truncate border-l-2 
                                                    <%= event.event_type === 'Exam' ? 'bg-red-50 text-red-700 border-red-500' : 
                                                        event.event_type === 'Deadline' ? 'bg-amber-50 text-amber-700 border-amber-500' : 
                                                        'bg-blue-50 text-blue-700 border-blue-500' %>">
                                                    <%= event.event_title %>
                                                </div>
                                            <% }) %>
                                        </div>
                                    </div>
                                <% } 

                                const totalSlots = 42; 
                                const remainingSlots = totalSlots - (firstDayOfMonth + daysInMonth);
                                for (let i = 1; i <= remainingSlots; i++) { %>
                                    <div class="border-r border-b border-slate-50 p-2 bg-slate-50/30">
                                        <span class="text-xs font-bold text-slate-200"><%= i %></span>
                                    </div>
                                <% } 
                            %>
                        </div>
                    </div>

                    <div id="agendaView" class="hidden space-y-4">
                        <% if (events && events.length > 0) { %>
                            <% events.forEach(event => { %>
                                <div class="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm hover:shadow-md transition-all flex flex-col md:flex-row gap-6">
                                    <div class="flex flex-col items-center justify-center bg-slate-100 rounded-2xl px-4 py-2 min-w-[80px]">
                                        <span class="text-[10px] font-black uppercase text-slate-400"><%= new Date(event.event_date).toLocaleString('default', { month: 'short' }) %></span>
                                        <span class="text-2xl font-black text-slate-800"><%= new Date(event.event_date).getDate() %></span>
                                    </div>

                                    <div class="flex-1">
                                        <div class="flex flex-wrap items-center gap-2 mb-2">
                                            <span class="px-2 py-1 bg-blue-50 text-blue-600 text-[10px] font-black rounded-md uppercase tracking-tighter">
                                                <%= event.subject_name %>
                                            </span>
                                            <span class="px-2 py-1 bg-slate-100 text-slate-600 text-[10px] font-black rounded-md uppercase tracking-tighter">
                                                <%= event.event_type %>
                                            </span>
                                            <% if(event.is_repeatable) { %>
                                                <span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-black rounded-md uppercase tracking-tighter">
                                                    <i class="fas fa-redo mr-1"></i> <%= event.repeat_cycle %>
                                                </span>
                                            <% } %>
                                        </div>
                                        <h4 class="text-lg font-bold text-slate-800"><%= event.event_title %></h4>
                                        <p class="text-slate-500 text-sm mb-3"><%= event.event_description %></p>
                                        
                                        <div class="flex flex-wrap gap-4 text-xs text-slate-400 font-medium">
                                            <div class="flex items-center gap-1">
                                                <i class="fas fa-location-dot"></i> <%= event.event_location %>
                                            </div>
                                            <% if(event.duration_type === 'DateRange') { %>
                                                <div class="flex items-center gap-1">
                                                    <i class="fas fa-clock"></i> 
                                                    <%= new Date(event.start_date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> - 
                                                    <%= new Date(event.end_date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                                </div>
                                            <% } else if(event.duration_type === 'Minutes') { %>
                                                <div class="flex items-center gap-1">
                                                    <i class="fas fa-stopwatch"></i> <%= event.duration_minutes %> Minutes
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-slate-200">
                                <i class="fas fa-calendar-xmark text-4xl text-slate-200 mb-4"></i>
                                <p class="text-slate-400 font-medium">No upcoming events scheduled.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>

            </div> <div id="notification-overlay" 
                onclick="toggleNotifications()" 
                class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[60] hidden transition-opacity duration-300 opacity-0">
            </div>

            <div id="notification-panel" 
                class="fixed top-0 right-0 h-screen w-80 md:w-96 bg-white shadow-2xl z-[70] transform translate-x-full transition-transform duration-300 ease-in-out border-l border-slate-200 flex flex-col">
                
                <div class="p-5 border-b flex justify-between items-center bg-blue-600 text-white flex-shrink-0">
                    <h2 class="text-lg font-bold flex items-center gap-2">
                        <i class="far fa-bell"></i> Notifications
                    </h2>
                    <button onclick="toggleNotifications()" class="hover:bg-blue-700 p-2 rounded-lg transition">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50 no-scrollbar" id="notification-list">
                    <div id="notification-loader" class="flex flex-col items-center justify-center h-full text-slate-400">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mb-2"></div>
                        <p class="text-xs font-bold uppercase tracking-wider">Loading Arcade Updates...</p>
                    </div>
                </div>
            </div>

        <div id="eventModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] hidden flex items-center justify-center p-4">
            <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
                <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                    <h3 class="text-xl font-bold text-slate-800">Create New Event</h3>
                    <button onclick="closeEventModal()" class="text-slate-400 hover:text-slate-600 transition">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                
                <form action="/events/add" method="POST" class="p-6 space-y-4 max-h-[70vh] overflow-y-auto no-scrollbar">
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Subject</label>
                        <select name="subject_id" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                            <% userSubjects.forEach(sub => { %>
                                <option value="<%= sub.subject_id %>"><%= sub.subject_name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Event Title</label>
                            <input type="text" name="event_title" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Description</label>
                            <textarea name="event_description" rows="2" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                        </div>
                        <div>
                            <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Type</label>
                            <select name="event_type" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm outline-none">
                                <option>Material</option>
                                <option>Deadline</option>
                                <option>Exam</option>
                                <option>Holiday</option>
                                <option>Arcade Session</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Date</label>
                            <input type="date" name="event_date" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm outline-none">
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Location</label>
                        <input type="text" name="event_location" placeholder="Room 101 or Online Link" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-blue-500">
                    </div>

                    <div class="p-4 bg-blue-50 rounded-2xl border border-blue-100">
                        <label class="block text-xs font-black uppercase tracking-widest text-blue-400 mb-3">Duration Settings</label>
                        <select name="duration_type" id="durationType" onchange="toggleDurationFields()" class="w-full px-4 py-2 bg-white border border-blue-200 rounded-xl text-sm outline-none mb-3">
                            <option value="None">No Duration</option>
                            <option value="DateRange">Date Range (Start & End)</option>
                            <option value="Minutes">Set in Minutes</option>
                        </select>

                        <div id="dateRangeFields" class="hidden grid grid-cols-2 gap-3">
                            <input type="datetime-local" name="start_date" class="px-3 py-2 bg-white border border-blue-200 rounded-xl text-xs">
                            <input type="datetime-local" name="end_date" class="px-3 py-2 bg-white border border-blue-200 rounded-xl text-xs">
                        </div>

                        <div id="minuteFields" class="hidden">
                            <input type="number" name="duration_minutes" placeholder="How many minutes?" class="w-full px-3 py-2 bg-white border border-blue-200 rounded-xl text-xs">
                        </div>
                    </div>

                    <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-200">
                        <input type="checkbox" name="is_repeatable" id="isRepeatable" onchange="toggleRepeatFields()" class="w-5 h-5 accent-blue-600">
                        <label for="isRepeatable" class="text-sm font-bold text-slate-700">Repeat this event</label>
                        
                        <select name="repeat_cycle" id="repeatCycle" class="hidden ml-auto px-3 py-2 bg-white border border-slate-200 rounded-xl text-xs outline-none">
                            <option value="Daily">Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>

                    <button type="submit" class="w-full py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-blue-600 transition-all shadow-lg">
                        Save Event
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        async function toggleNotifications() {
            const panel = document.getElementById('notification-panel');
            const overlay = document.getElementById('notification-overlay');
            const list = document.getElementById('notification-list');

            if (panel.classList.contains('translate-x-full')) {
                // OPEN PANEL
                panel.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);

                // FETCH DATA FROM DATABASE
                try {
                    const response = await fetch('/api/notifications'); 
                    const notifications = await response.json();

                    list.innerHTML = '';

                    if (notifications.length === 0) {
                        list.innerHTML = `
                            <div class="flex flex-col items-center justify-center h-64 text-gray-400">
                                <i class="fas fa-check-circle text-4xl mb-2 opacity-20"></i>
                                <p>All caught up!</p>
                            </div>`;
                        return;
                    }

                    notifications.forEach(notif => {
                        const timeAgo = formatTimeAgo(notif.created_at);
                        
                        // --- DYNAMIC CONFIGURATION BASED ON TYPE ---
                        let config = {
                            icon: 'fa-info-circle',
                            border: 'border-gray-500',
                            badge: 'bg-gray-100 text-gray-600',
                            label: notif.type
                        };

                        switch(notif.type) {
                            case 'announcement':
                                config = { icon: 'fa-bullhorn', border: 'border-blue-500', badge: 'bg-blue-100 text-blue-600', label: 'Announcement' };
                                break;
                            case 'assessment':
                                config = { icon: 'fa-file-alt', border: 'border-red-500', badge: 'bg-red-100 text-red-600', label: 'Assessment' };
                                break;
                            case 'material':
                                config = { icon: 'fa-book', border: 'border-purple-500', badge: 'bg-purple-100 text-purple-600', label: 'New Material' };
                                break;
                            case 'forum_new':
                            case 'forum_reply':
                                config = { icon: 'fa-comments', border: 'border-green-500', badge: 'bg-green-100 text-green-600', label: 'Forum' };
                                break;
                            case 'score':
                                config = { icon: 'fa-star', border: 'border-yellow-500', badge: 'bg-yellow-100 text-yellow-700', label: 'Result' };
                                break;
                        }

                        // --- BUILD EXTRA INFO (EXP GAINED / SUBJECT NAME) ---
                        let extraBadge = '';
                        if (notif.extra_info) {
                            const isExp = notif.extra_info.includes('EXP');
                            extraBadge = `<span class="mt-1 inline-block px-2 py-0.5 rounded text-[10px] font-bold ${isExp ? 'bg-green-500 text-white' : 'bg-slate-200 text-slate-700'}">${notif.extra_info}</span>`;
                        }

                        const itemHTML = `
                            <div class="bg-white p-3 rounded-lg border-l-4 ${config.border} shadow-sm hover:shadow-md transition-all cursor-pointer group">
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-[9px] font-bold uppercase px-1.5 py-0.5 rounded ${config.badge}">
                                        <i class="fas ${config.icon} mr-1"></i>${config.label}
                                    </span>
                                    <span class="text-[10px] text-gray-400 group-hover:text-gray-600">${timeAgo}</span>
                                </div>
                                <p class="text-sm font-bold text-gray-800 leading-tight">${notif.heading}</p>
                                <p class="text-xs text-gray-500 mt-0.5 line-clamp-2">${notif.snippet}</p>
                                ${extraBadge}
                            </div>
                        `;
                        list.insertAdjacentHTML('beforeend', itemHTML);
                    });

                } catch (err) {
                    list.innerHTML = `<p class="text-center text-red-500 p-4">Failed to load notifications.</p>`;
                    console.error(err);
                }
            } else {
                // CLOSE PANEL
                panel.classList.add('translate-x-full');
                overlay.classList.remove('opacity-100');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        function formatTimeAgo(dateString) {
            if (!dateString) return '';
            const now = new Date();
            const past = new Date(dateString);
            const diffInMs = now - past;
            const diffInMins = Math.floor(diffInMs / 60000);
            
            if (diffInMins < 0) return 'Upcoming'; // For future due dates
            if (diffInMins < 1) return 'Just now';
            if (diffInMins < 60) return `${diffInMins}m ago`;
            const diffInHours = Math.floor(diffInMins / 60);
            if (diffInHours < 24) return `${diffInHours}h ago`;
            return past.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            
            if (window.innerWidth < 768) {
                sidebar.classList.toggle('sidebar-collapsed');
                sidebar.classList.toggle('sidebar-open');
                overlay.classList.toggle('hidden');
            } else {
                // For desktop, usually you'd toggle a mini-sidebar or just leave it
                sidebar.classList.toggle('sidebar-collapsed');
                document.getElementById('mainContent').classList.toggle('md:ml-64');
                document.getElementById('mainContent').classList.toggle('md:ml-0');
            }
        }

        function toggleUserMenu(event) {
            event.stopPropagation();
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('hidden');
        }

        // Close dropdown when clicking outside
        window.addEventListener('click', function() {
            const dropdown = document.getElementById('userDropdown');
            if (!dropdown.classList.contains('hidden')) {
                dropdown.classList.add('hidden');
            }
        });

        // Auto-handle sidebar on resize
        window.addEventListener('resize', () => {
            const sidebar = document.getElementById('sidebar');
            const main = document.getElementById('mainContent');
            if (window.innerWidth >= 768) {
                sidebar.classList.remove('sidebar-collapsed', 'sidebar-open');
                main.classList.add('md:ml-64');
            } else {
                sidebar.classList.add('sidebar-collapsed');
                main.classList.remove('md:ml-64');
            }
        });

        function switchView(view) {
        const grid = document.getElementById('gridView');
        const agenda = document.getElementById('agendaView');
        const btnGrid = document.getElementById('btnGrid');
        const btnAgenda = document.getElementById('btnAgenda');

        if (view === 'grid') {
            grid.classList.remove('hidden');
            agenda.classList.add('hidden');
            btnGrid.className = 'px-4 py-2 rounded-xl text-sm font-bold transition-all bg-slate-100 text-blue-600';
            btnAgenda.className = 'px-4 py-2 rounded-xl text-sm font-bold transition-all text-slate-500 hover:bg-slate-50';
        } else {
            grid.classList.add('hidden');
            agenda.classList.remove('hidden');
            btnAgenda.className = 'px-4 py-2 rounded-xl text-sm font-bold transition-all bg-slate-100 text-blue-600';
            btnGrid.className = 'px-4 py-2 rounded-xl text-sm font-bold transition-all text-slate-500 hover:bg-slate-50';
        }
    }

        function openEventModal() { document.getElementById('eventModal').classList.remove('hidden'); }
        function closeEventModal() { document.getElementById('eventModal').classList.add('hidden'); }

        function toggleDurationFields() {
            const type = document.getElementById('durationType').value;
            document.getElementById('dateRangeFields').classList.toggle('hidden', type !== 'DateRange');
            document.getElementById('minuteFields').classList.toggle('hidden', type !== 'Minutes');
        }

        function toggleRepeatFields() {
            const isChecked = document.getElementById('isRepeatable').checked;
            document.getElementById('repeatCycle').classList.toggle('hidden', !isChecked);
        }
    </script>
</body>
</html>