<!DOCTYPE html>
<html>
<head>
    <title>Setup Your Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Anti-back logic
        window.history.pushState(null, null, window.location.href);
        window.onpopstate = function () { window.history.go(1); };

        // Client-side validation
        function validateForm(event) {
            const pass = document.getElementById('password').value;
            const confirm = document.getElementById('confirm_password').value;
            const errorMsg = document.getElementById('error-message');

            if (pass !== confirm) {
                event.preventDefault(); // Pipigilan ang submit
                errorMsg.classList.remove('hidden');
                return false;
            }
            return true;
        }
    </script>
</head>
<body class="bg-blue-50 flex items-center justify-center min-h-screen">
    <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border-t-4 border-blue-600">
        <h2 class="text-2xl font-bold text-slate-800 mb-2">Final Step! 🚀</h2>
        <p class="text-gray-600 mb-6">Hello <b><%= user.first_name %> <%= user.last_name %></b>, set your account password to finalize your registration.</p>
        
        <div id="error-message" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded mb-4 text-sm">
            Passwords do not match! Please try again.
        </div>

        <form action="/complete-registration" method="POST" onsubmit="return validateForm(event)" class="space-y-4">
            <input type="hidden" name="email" value="<%= email %>">
            
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Gmail Address</label>
                <input type="text" value="<%= email %>" disabled class="w-full border p-3 rounded-xl bg-gray-50 text-gray-500 italic">
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Create Password</label>
                <input type="password" name="password" id="password" required minlength="8" placeholder="Minimum 8 characters"
                       class="w-full border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition">
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Confirm Password</label>
                <input type="password" name="confirm_password" id="confirm_password" required minlength="8" placeholder="Repeat your password"
                       class="w-full border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition">
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white p-4 rounded-xl font-bold hover:bg-blue-700 shadow-lg transition transform active:scale-95">
                Save and Finalize Account
            </button>
        </form>
    </div>
</body>
</html>