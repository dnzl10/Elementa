<!DOCTYPE html>
<html>
<head>
    <title>Login - Chemistry Arcade LMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 flex items-center justify-center min-h-screen">
    <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-2xl">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-slate-800">Chemistry Arcade</h1>
            <p class="text-slate-500">Learning Management System</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-semibold text-slate-700">Gmail Address</label>
                <input type="email" name="email" required class="w-full border-2 border-slate-200 p-3 rounded-xl focus:border-blue-500 outline-none transition">
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700">Password</label>
                <input type="password" name="password" required class="w-full border-2 border-slate-200 p-3 rounded-xl focus:border-blue-500 outline-none transition">
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white p-4 rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-200 transition">
                Login to System
            </button>
        </form>

        <div class="mt-8 border-t border-slate-100 pt-6">
            <p class="text-center text-sm text-slate-400 mb-4">Or continue with</p>
            <a href="/auth/google" class="flex items-center justify-center border-2 border-slate-200 p-3 rounded-xl hover:bg-slate-50 transition font-medium">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-5 h-5 mr-3">
                Sign in with Google
            </a>
        </div>
    </div>
</body>
</html>